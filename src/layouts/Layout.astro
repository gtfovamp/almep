---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Raleway:wght@400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles/global.css" />
    <!-- View Transitions API для плавных переходов -->
    <script>
      if ('startViewTransition' in document) {
        // Браузер поддерживает View Transitions
        document.addEventListener('astro:before-swap', () => {
          // Сохраняем позицию скролла
          sessionStorage.setItem('scrollY', window.scrollY.toString());
        });
        
        document.addEventListener('astro:page-load', () => {
          // Восстанавливаем скролл после перехода
          const scrollY = sessionStorage.getItem('scrollY');
          if (scrollY) {
            window.scrollTo(0, parseInt(scrollY));
            sessionStorage.removeItem('scrollY');
          }
        });
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* Анимация для View Transitions */
  @view-transition {
    navigation: auto;
  }
  
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0.3s;
  }
</style>