---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

let categories = [];
let subcategories = [];
try {
  const db = env.DB;
  if (db) {
    const { results: catResults } = await db.prepare(
      'SELECT * FROM categories ORDER BY order_index ASC'
    ).all();
    categories = catResults || [];

    const { results: subResults } = await db.prepare(
      'SELECT * FROM subcategories ORDER BY category_id ASC, order_index ASC'
    ).all();
    subcategories = subResults || [];
  }
} catch (error) {
  console.error('Error fetching data:', error);
}
---

<AdminLayout title="Subcategories" activeSection="subcategories">
  <link rel="stylesheet" href="/admin-styles.css">
  <style>
    .filter-bar {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 24px;
    }

    .filter-bar label {
      display: block;
      font-size: 14px;
      font-weight: 500;
      color: #374151;
      margin-bottom: 8px;
    }

    .filter-bar select {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      font-size: 14px;
      color: #1f2937;
      background: white;
      cursor: pointer;
    }

    .filter-bar select:focus {
      outline: none;
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }
  </style>

  <div class="admin-content">
    <section class="form-section" id="formSection">
      <div class="section-header">
        <h2 id="formTitle">Add New Subcategory</h2>
        <button type="button" class="btn btn-ghost" id="cancelEdit" style="display: none;">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Cancel
        </button>
      </div>

      <form id="subcategoryForm" class="admin-form">
        <div class="form-group">
          <label for="category_id">Parent Category *</label>
          <select id="category_id" name="category_id" required>
            <option value="">Select a category</option>
            {categories.map((cat: any) => (
              <option value={cat.id}>{cat.name}</option>
            ))}
          </select>
        </div>

        <div class="form-group">
          <label for="name">Name (RU) *</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="name_en">Name (EN)</label>
            <input type="text" id="name_en" name="name_en" />
          </div>
          <div class="form-group">
            <label for="name_az">Name (AZ)</label>
            <input type="text" id="name_az" name="name_az" />
          </div>
        </div>

        <div class="form-group">
          <label for="description">Description (RU)</label>
          <textarea id="description" name="description" rows="3"></textarea>
        </div>

        <div class="form-group">
          <label for="description_en">Description (EN)</label>
          <textarea id="description_en" name="description_en" rows="3"></textarea>
        </div>

        <div class="form-group">
          <label for="description_az">Description (AZ)</label>
          <textarea id="description_az" name="description_az" rows="3"></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="submitBtn">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 4V16M4 10H16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Add Subcategory
          </button>
        </div>
      </form>
    </section>

    <section class="list-section">
      <div class="section-header">
        <h2>Existing Subcategories</h2>
        <span class="item-count" id="itemCount">{subcategories.length} {subcategories.length === 1 ? 'subcategory' : 'subcategories'}</span>
      </div>

      <div class="filter-bar">
        <label for="filterCategory">Filter by Category</label>
        <select id="filterCategory">
          <option value="">All Categories</option>
          {categories.map((cat: any) => (
            <option value={cat.id}>{cat.name}</option>
          ))}
        </select>
      </div>

      {subcategories.length === 0 ? (
        <div class="empty-state">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
            <path d="M32 20v24M20 32h24" stroke="#ccc" stroke-width="2" stroke-linecap="round"/>
            <circle cx="32" cy="32" r="24" stroke="#ccc" stroke-width="2"/>
          </svg>
          <p>No subcategories yet</p>
          <span>Add your first subcategory using the form on the left</span>
        </div>
      ) : (
        <div class="item-list" id="subcategoryList">
          {subcategories.map((item: any) => {
            const category = categories.find((c: any) => c.id === item.category_id);
            return (
              <div class="item-card" data-id={item.id} data-order={item.order_index} data-category={item.category_id} draggable="true">
                <div class="item-drag">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <circle cx="7" cy="5" r="1.5" fill="#999"/>
                    <circle cx="13" cy="5" r="1.5" fill="#999"/>
                    <circle cx="7" cy="10" r="1.5" fill="#999"/>
                    <circle cx="13" cy="10" r="1.5" fill="#999"/>
                    <circle cx="7" cy="15" r="1.5" fill="#999"/>
                    <circle cx="13" cy="15" r="1.5" fill="#999"/>
                  </svg>
                </div>
                <div class="item-info">
                  <h3>{item.name}</h3>
                  {item.description && (
                    <p class="item-description">{item.description.substring(0, 100)}{item.description.length > 100 ? '...' : ''}</p>
                  )}
                  <div class="item-meta">
                    <span class="meta-badge">{category?.name || 'Unknown'}</span>
                    {item.name_en && <span class="meta-lang">EN</span>}
                    {item.name_az && <span class="meta-lang">AZ</span>}
                  </div>
                </div>
                <div class="item-actions">
                  <button class="btn btn-icon btn-edit" onclick={`subcategoryManager.edit(${item.id})`}>
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <path d="M12.5 2.5L15.5 5.5L6 15H3V12L12.5 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <button class="btn btn-icon btn-danger" onclick={`subcategoryManager.delete(${item.id})`}>
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <path d="M3 5H15M7 8V13M11 8V13M4 5L5 15H13L14 5M7 5V3H11V5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </section>
  </div>

  <script src="/admin-manager.js" is:inline></script>
  <script is:inline>
    class SubcategoryManager extends PortfolioManager {
      constructor(config) {
        super(config);
        this.setupFilter();
      }

      setupFilter() {
        const filterSelect = document.getElementById('filterCategory');
        filterSelect?.addEventListener('change', () => {
          this.filterByCategory(filterSelect.value);
        });
      }

      filterByCategory(categoryId) {
        const cards = document.querySelectorAll('.item-card');
        let visibleCount = 0;

        cards.forEach(card => {
          if (!categoryId || card.dataset.category === categoryId) {
            card.style.display = 'flex';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        const itemCount = document.getElementById('itemCount');
        if (itemCount) {
          itemCount.textContent = `${visibleCount} ${visibleCount === 1 ? 'subcategory' : 'subcategories'}`;
        }
      }

      async edit(id) {
        try {
          const response = await fetch(`/api/subcategories/${id}`);
          const item = await response.json();

          this.editingId = id;
          document.getElementById('formTitle').textContent = 'Edit Subcategory';
          document.getElementById('submitBtn').innerHTML = `
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16 5L7 14L3 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Update Subcategory
          `;
          document.getElementById('cancelEdit').style.display = 'flex';

          document.getElementById('category_id').value = item.category_id || '';
          document.getElementById('category_id').disabled = true;
          document.getElementById('name').value = item.name || '';
          document.getElementById('name_en').value = item.name_en || '';
          document.getElementById('name_az').value = item.name_az || '';
          document.getElementById('description').value = item.description || '';
          document.getElementById('description_en').value = item.description_en || '';
          document.getElementById('description_az').value = item.description_az || '';
        } catch (error) {
          console.error('Edit error:', error);
          alert('Failed to load subcategory');
        }
      }

      resetForm() {
        super.resetForm();
        document.getElementById('category_id').disabled = false;
      }
    }

    window.subcategoryManager = new SubcategoryManager({
      apiEndpoint: '/api/subcategories',
      formId: 'subcategoryForm',
      listId: 'subcategoryList'
    });
  </script>
</AdminLayout>
