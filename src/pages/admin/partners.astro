---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

let partners = [];
try {
  const db = env.DB;
  if (db) {
    const { results } = await db.prepare(
      'SELECT * FROM partners ORDER BY order_index ASC'
    ).all();
    partners = results || [];
  }
} catch (error) {
  console.error('Error fetching partners:', error);
}
---

<AdminLayout title="Partners" activeSection="partners">
  <link rel="stylesheet" href="/admin-styles.css">

  <div class="admin-content">
    <section class="form-section" id="formSection">
      <div class="section-header">
        <h2 id="formTitle">Add New Partner</h2>
        <button type="button" class="btn btn-ghost" id="cancelEdit" style="display: none;">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Cancel
        </button>
      </div>

      <form id="partnerForm" class="admin-form" enctype="multipart/form-data">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Name (RU) *</label>
            <input type="text" id="name" name="name" required />
          </div>
          <div class="form-group">
            <label for="name_en">Name (EN)</label>
            <input type="text" id="name_en" name="name_en" />
          </div>
        </div>

        <div class="form-group">
          <label for="name_az">Name (AZ)</label>
          <input type="text" id="name_az" name="name_az" />
        </div>

        <div class="form-group">
          <label for="description">Description (RU)</label>
          <textarea id="description" name="description" rows="3"></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="description_en">Description (EN)</label>
            <textarea id="description_en" name="description_en" rows="3"></textarea>
          </div>
          <div class="form-group">
            <label for="description_az">Description (AZ)</label>
            <textarea id="description_az" name="description_az" rows="3"></textarea>
          </div>
        </div>

        <div class="form-group">
          <label for="image">
            Logo/Image *
            <span class="label-hint">Recommended: transparent PNG</span>
          </label>
          <div class="file-upload" id="fileUpload">
            <input type="file" id="image" name="image" accept="image/*" required />
            <div class="file-upload-placeholder">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <path d="M24 16V32M16 24H32" stroke="#7c3aed" stroke-width="2" stroke-linecap="round"/>
                <rect x="4" y="4" width="40" height="40" rx="4" stroke="#7c3aed" stroke-width="2"/>
              </svg>
              <span>Click or drag image here</span>
            </div>
            <div class="file-upload-preview" style="display: none;">
              <img src="" alt="Preview" />
              <button type="button" class="file-upload-remove">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path d="M15 5L5 15M5 5L15 15" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="submitBtn">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 4V16M4 10H16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Add Partner
          </button>
        </div>
      </form>
    </section>

    <section class="list-section">
      <div class="section-header">
        <h2>Existing Partners</h2>
        <span class="item-count">{partners.length} {partners.length === 1 ? 'partner' : 'partners'}</span>
      </div>

      {partners.length === 0 ? (
        <div class="empty-state">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
            <path d="M32 20v24M20 32h24" stroke="#ccc" stroke-width="2" stroke-linecap="round"/>
            <circle cx="32" cy="32" r="24" stroke="#ccc" stroke-width="2"/>
          </svg>
          <p>No partners yet</p>
          <span>Add your first partner using the form above</span>
        </div>
      ) : (
        <div class="item-list" id="partnerList">
          {partners.map((partner: any) => (
            <div class="item-card" data-id={partner.id} data-order={partner.order_index} draggable="true">
              <div class="item-drag">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <circle cx="7" cy="5" r="1.5" fill="#999"/>
                  <circle cx="13" cy="5" r="1.5" fill="#999"/>
                  <circle cx="7" cy="10" r="1.5" fill="#999"/>
                  <circle cx="13" cy="10" r="1.5" fill="#999"/>
                  <circle cx="7" cy="15" r="1.5" fill="#999"/>
                  <circle cx="13" cy="15" r="1.5" fill="#999"/>
                </svg>
              </div>
              <div class="item-image" style="background: white; display: flex; align-items: center; justify-content: center; padding: 12px;">
                <img src={partner.image_url} alt={partner.name} style="max-width: 100%; max-height: 100%; object-fit: contain;" />
              </div>
              <div class="item-info">
                <h3>{partner.name}</h3>
                <div class="item-meta">
                  {partner.name_en && <span class="meta-lang">EN</span>}
                  {partner.name_az && <span class="meta-lang">AZ</span>}
                  {partner.description && <span class="meta-badge">Has description</span>}
                </div>
              </div>
              <div class="item-actions">
                <button class="btn btn-icon btn-edit" onclick={`partnersManager.edit(${partner.id})`}>
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M12.5 2.5L15.5 5.5L6 15H3V12L12.5 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <button class="btn btn-icon btn-danger" onclick={`partnersManager.delete(${partner.id})`}>
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M3 5H15M7 8V13M11 8V13M4 5L5 15H13L14 5M7 5V3H11V5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            </div>
          ))}
        </div>
      )}
    </section>
  </div>

  <script src="/admin-manager.js" is:inline></script>
  <script is:inline>
    window.partnersManager = new PartnersManager({
      apiEndpoint: '/api/partners',
      formId: 'partnerForm',
      listId: 'partnerList'
    });
  </script>
</AdminLayout>
