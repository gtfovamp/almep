---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

let testimonials = [];
let pendingTestimonials = [];
try {
  const db = env.DB;
  if (db) {
    // Get approved testimonials
    const { results: approved } = await db.prepare(
      'SELECT * FROM testimonials WHERE approved = 1 ORDER BY order_index ASC'
    ).all();
    testimonials = approved || [];

    // Get pending testimonials
    const { results: pending } = await db.prepare(
      'SELECT * FROM testimonials WHERE approved = 0 ORDER BY created_at DESC'
    ).all();
    pendingTestimonials = pending || [];
  }
} catch (error) {
  console.error('Error fetching testimonials:', error);
}
---

<AdminLayout title="Testimonials" activeSection="testimonials">
  <link rel="stylesheet" href="/admin-styles.css">
  <style>
    .admin-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      max-width: 1600px;
    }

    .pending-section {
      background: #fff9e6;
      border: 2px solid #fbbf24;
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 32px;
    }

    .pending-section h2 {
      color: #92400e;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .pending-badge {
      background: #fbbf24;
      color: #92400e;
      padding: 4px 12px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 600;
    }

    .pending-item {
      background: white;
      border: 1px solid #fbbf24;
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 12px;
    }

    .pending-item h4 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 8px;
      color: #1a1a1a;
    }

    .pending-item p {
      font-size: 14px;
      color: #666;
      margin-bottom: 12px;
      line-height: 1.5;
    }

    .pending-actions {
      display: flex;
      gap: 8px;
    }

    .btn-approve {
      background: #10b981;
      color: white;
      padding: 8px 16px;
      border: none;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: all 0.2s;
    }

    .btn-approve:hover {
      background: #059669;
    }

    .btn-edit-pending {
      background: #3b82f6;
      color: white;
      padding: 8px 16px;
      border: none;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: all 0.2s;
    }

    .btn-edit-pending:hover {
      background: #2563eb;
    }
  </style>

  <div class="admin-content">
    <!-- Pending Testimonials Section -->
    {pendingTestimonials.length > 0 && (
      <div style="grid-column: 1 / -1;">
        <div class="pending-section">
          <h2>
            Pending Approval
            <span class="pending-badge">{pendingTestimonials.length}</span>
          </h2>
          {pendingTestimonials.map((item: any) => (
            <div class="pending-item" data-id={item.id}>
              <h4>{item.name}</h4>
              <p>{item.text}</p>
              <div class="pending-actions">
                <button class="btn-edit-pending" onclick={`testimonialManager.editPending(${item.id})`}>
                  <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
                    <path d="M12.5 2.5L15.5 5.5L6 15H3V12L12.5 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Add Translations
                </button>
                <button class="btn-approve" onclick={`testimonialManager.approve(${item.id})`}>
                  <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                    <path d="M16 5L7 14L3 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                  Approve
                </button>
                <button class="btn btn-icon btn-danger" onclick={`testimonialManager.delete(${item.id})`}>
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M3 5H15M7 8V13M11 8V13M4 5L5 15H13L14 5M7 5V3H11V5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <section class="form-section" id="formSection">
      <div class="section-header">
        <h2 id="formTitle">Add New Testimonial</h2>
        <button type="button" class="btn btn-ghost" id="cancelEdit" style="display: none;">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Cancel
        </button>
      </div>

      <form id="testimonialForm" class="admin-form">
        <div class="form-group">
          <label for="name">Name / Company (RU) *</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="name_en">Name / Company (EN)</label>
            <input type="text" id="name_en" name="name_en" />
          </div>
          <div class="form-group">
            <label for="name_az">Name / Company (AZ)</label>
            <input type="text" id="name_az" name="name_az" />
          </div>
        </div>

        <div class="form-group">
          <label for="text">Testimonial Text (RU) *</label>
          <textarea id="text" name="text" rows="4" required></textarea>
        </div>

        <div class="form-group">
          <label for="text_en">Testimonial Text (EN)</label>
          <textarea id="text_en" name="text_en" rows="4"></textarea>
        </div>

        <div class="form-group">
          <label for="text_az">Testimonial Text (AZ)</label>
          <textarea id="text_az" name="text_az" rows="4"></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="submitBtn">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 4V16M4 10H16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Add Testimonial
          </button>
        </div>
      </form>
    </section>

    <section class="list-section">
      <div class="section-header">
        <h2>Existing Testimonials</h2>
        <span class="item-count">{testimonials.length} {testimonials.length === 1 ? 'testimonial' : 'testimonials'}</span>
      </div>

      {testimonials.length === 0 ? (
        <div class="empty-state">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
            <path d="M32 20v24M20 32h24" stroke="#ccc" stroke-width="2" stroke-linecap="round"/>
            <circle cx="32" cy="32" r="24" stroke="#ccc" stroke-width="2"/>
          </svg>
          <p>No testimonials yet</p>
          <span>Add your first testimonial using the form on the left</span>
        </div>
      ) : (
        <div class="item-list" id="testimonialList">
          {testimonials.map((item: any) => (
            <div class="item-card" data-id={item.id} data-order={item.order_index} draggable="true">
              <div class="item-drag">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <circle cx="7" cy="5" r="1.5" fill="#999"/>
                  <circle cx="13" cy="5" r="1.5" fill="#999"/>
                  <circle cx="7" cy="10" r="1.5" fill="#999"/>
                  <circle cx="13" cy="10" r="1.5" fill="#999"/>
                  <circle cx="7" cy="15" r="1.5" fill="#999"/>
                  <circle cx="13" cy="15" r="1.5" fill="#999"/>
                </svg>
              </div>
              <div class="item-info">
                <h3>{item.name}</h3>
                <p class="item-description">{item.text.substring(0, 100)}{item.text.length > 100 ? '...' : ''}</p>
                <div class="item-meta">
                  {item.name_en && <span class="meta-lang">EN</span>}
                  {item.name_az && <span class="meta-lang">AZ</span>}
                </div>
              </div>
              <div class="item-actions">
                <button class="btn btn-icon btn-edit" onclick={`testimonialManager.edit(${item.id})`}>
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M12.5 2.5L15.5 5.5L6 15H3V12L12.5 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <button class="btn btn-icon btn-danger" onclick={`testimonialManager.delete(${item.id})`}>
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M3 5H15M7 8V13M11 8V13M4 5L5 15H13L14 5M7 5V3H11V5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            </div>
          ))}
        </div>
      )}
    </section>
  </div>

  <script src="/admin-manager.js" is:inline></script>
  <script is:inline>
    class TestimonialManager extends PortfolioManager {
      constructor(config) {
        super(config);
        // Re-bind submit handler
        this.form.removeEventListener('submit', this.handleSubmit);
        this.form.addEventListener('submit', (e) => this.handleSubmit(e));
      }

      async approve(id) {
        if (!confirm('Approve this testimonial?')) return;

        try {
          const response = await fetch('/api/testimonials/approve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id })
          });

          if (response.ok) {
            window.location.reload();
          } else {
            alert('Failed to approve testimonial');
          }
        } catch (error) {
          console.error('Approve error:', error);
          alert('Failed to approve testimonial');
        }
      }

      async editPending(id) {
        try {
          const response = await fetch(`/api/testimonials/${id}`);
          const item = await response.json();

          this.editingId = id;
          this.isPendingEdit = true;
          document.getElementById('formTitle').textContent = 'Add Translations & Approve';
          document.getElementById('submitBtn').innerHTML = `
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16 5L7 14L3 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Save & Approve
          `;
          document.getElementById('cancelEdit').style.display = 'flex';

          document.getElementById('name').value = item.name || '';
          document.getElementById('name').disabled = true;
          document.getElementById('name_en').value = item.name_en || '';
          document.getElementById('name_az').value = item.name_az || '';
          document.getElementById('text').value = item.text || '';
          document.getElementById('text').disabled = true;
          document.getElementById('text_en').value = item.text_en || '';
          document.getElementById('text_az').value = item.text_az || '';

          // Scroll to form
          document.getElementById('formSection').scrollIntoView({ behavior: 'smooth' });
        } catch (error) {
          console.error('Edit pending error:', error);
          alert('Failed to load testimonial');
        }
      }

      async edit(id) {
        try {
          const response = await fetch(`/api/testimonials/${id}`);
          const item = await response.json();

          this.editingId = id;
          this.isPendingEdit = false;
          document.getElementById('formTitle').textContent = 'Edit Testimonial';
          document.getElementById('submitBtn').innerHTML = `
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16 5L7 14L3 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Update Testimonial
          `;
          document.getElementById('cancelEdit').style.display = 'flex';

          document.getElementById('name').value = item.name || '';
          document.getElementById('name').disabled = false;
          document.getElementById('name_en').value = item.name_en || '';
          document.getElementById('name_az').value = item.name_az || '';
          document.getElementById('text').value = item.text || '';
          document.getElementById('text').disabled = false;
          document.getElementById('text_en').value = item.text_en || '';
          document.getElementById('text_az').value = item.text_az || '';
        } catch (error) {
          console.error('Edit error:', error);
          alert('Failed to load testimonial');
        }
      }

      resetForm() {
        super.resetForm();
        this.isPendingEdit = false;
        document.getElementById('name').disabled = false;
        document.getElementById('text').disabled = false;
      }

      async handleSubmit(e) {
        e.preventDefault();
        const formData = new FormData(this.form);

        try {
          let url = this.editingId
            ? `${this.apiEndpoint}/${this.editingId}`
            : `${this.apiEndpoint}/create`;

          let method = this.editingId ? 'PUT' : 'POST';

          const response = await fetch(url, { method, body: formData });

          if (response.ok) {
            // If editing a pending item, also approve it
            if (this.isPendingEdit && this.editingId) {
              await this.approve(this.editingId);
            } else {
              window.location.reload();
            }
          } else {
            const error = await response.json();
            alert(error.error || 'Failed to save testimonial');
          }
        } catch (error) {
          console.error('Submit error:', error);
          alert('Failed to save testimonial');
        }
      }
    }

    window.testimonialManager = new TestimonialManager({
      apiEndpoint: '/api/testimonials',
      formId: 'testimonialForm',
      listId: 'testimonialList'
    });
  </script>
</AdminLayout>
