---
interface NavLink {
  label: string;
  href: string;
  active?: boolean;
  dropdown?: boolean;
}

interface Props {
  links: NavLink[];
}

const { links } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <ul class="nav__list">
    {links.map((link) => {
      const isActive = currentPath === link.href;
      return (
        <li class={`nav__item ${isActive ? 'nav__item--active' : ''} ${link.dropdown ? 'nav__item--has-dropdown' : ''}`}>
          <a href={link.href} class="nav__link">
            {link.label}
            {link.dropdown && (
              <svg class="nav__arrow" width="15" height="8" viewBox="0 0 15 8" fill="none">
                <path d="M1 1L7.5 7L14 1" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
          </a>

          {/* Подчёркивание активного пункта */}
          {isActive && <span class="nav__underline" />}

          {/* Дропдаун для "О компании" */}
          {link.dropdown && (
            <div class="nav__dropdown">
              <div class="nav__dropdown-header">
                <span>О нас</span>
              </div>
              <ul class="nav__dropdown-list">
                <li>
                  <a href="/about/structure" class="nav__dropdown-link">
                    Структура компании
                  </a>
                </li>
                <li>
                  <a href="/about/certificates" class="nav__dropdown-link">
                    Сертификаты и лицензии
                  </a>
                </li>
                <li>
                  <a href="/about/blog" class="nav__dropdown-link">
                    Блог
                  </a>
                </li>
              </ul>
            </div>
          )}
        </li>
      );
    })}
  </ul>
</nav>

<style>
  .nav__list {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 61px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 5px;
    position: relative;
  }

  .nav__link {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 5px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    letter-spacing: -0.01em;
    color: #FFFFFF;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .nav__link:hover {
    opacity: 0.8;
  }

  .nav__item--active .nav__link {
    font-weight: 500;
  }

  /* Подчёркивание активного пункта — выровнено по правому краю */
  .nav__underline {
    display: block;
    width: 42px;
    height: 1px;
    background: #FFFFFF;
    align-self: flex-end;
  }

  .nav__arrow {
    transition: transform 0.2s ease;
  }

  /* === Дропдаун "О компании" === */
  .nav__dropdown {
    position: absolute;
    /* Прижат к верху li — появляется прямо под ссылкой */
    top: 100%;
    left: 0;
    width: 234px;
    background: #FFFFFF;
    box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.15);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 200;
    padding-bottom: 15px;
  }

  /* Показываем при hover на li */
  .nav__item--has-dropdown:hover .nav__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* Поворот стрелки при hover */
  .nav__item--has-dropdown:hover .nav__arrow {
    transform: rotate(180deg);
  }

  /* Заголовок дропдауна "О нас" */
  .nav__dropdown-header {
    display: flex;
    align-items: center;
    height: 35px;
    padding: 0 10px;
    margin: 20px 15px 0;
    background: #E7E7E7;
  }

  .nav__dropdown-header span {
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    color: #000000;
  }

  /* Список пунктов */
  .nav__dropdown-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav__dropdown-link {
    display: block;
    padding: 15px 20px 0;
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    color: #000000;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .nav__dropdown-link:hover {
    color: #1C508F;
  }
</style>