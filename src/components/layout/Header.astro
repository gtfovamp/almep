---
import Nav from './Nav.astro';
import { getLangLabel, type Lang } from '../../utils/i18n';

interface Props {
  t: any;
  lang: Lang;
}

const { t, lang } = Astro.props;

const currentPath = new URL(Astro.request.url).pathname;
const pathWithoutLang = currentPath.replace(/^\/(ru|en|az)/, '') || '/';

const navLinks = [
  { label: t.nav.home, href: `/${lang}`, active: pathWithoutLang === '/' },
  { label: t.nav.about, href: `/${lang}/about`, dropdown: true },
  { label: t.nav.services, href: `/${lang}/services` },
  { label: t.nav.products, href: `/${lang}/products` },
  { label: t.nav.partners, href: `/${lang}/partners` },
  { label: t.nav.portfolio, href: `/${lang}/portfolio` },
  { label: t.nav.news, href: `/${lang}/news` },
  { label: t.nav.reviews, href: `/${lang}/reviews` },
  { label: t.nav.contacts, href: `/${lang}/contacts` },
];

const currentLangLabel = getLangLabel(lang);
const otherLangs = [
  { code: 'ru', label: 'RU' },
  { code: 'en', label: 'EN' },
  { code: 'az', label: 'AZ' },
].filter(l => l.code !== lang);
---

<header class="header">
  <div class="header__inner">
    <!-- Мобильный хедер -->
    <div class="header__mobile">
      <a href={`/${lang}`} class="header__mobile-logo">
        <img src="/assets/icons/logo.svg" alt="Almep Trading" width="126" height="31" />
      </a>
      <div class="header__mobile-actions">
        <button class="header__mobile-search" id="mobileSearchToggle" aria-label="Поиск">
          <img src="/assets/icons/search.svg" alt="Поиск" width="33" height="33" />
        </button>
        <button class="header__mobile-menu" id="mobileMenuToggle" aria-label="Меню">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>

    <!-- Мобильная панель поиска -->
    <div class="header__mobile-search-panel" id="mobileSearchPanel">
      <div class="header__mobile-search-top">
        <a href={`/${lang}`} class="header__mobile-search-logo">
          <img src="/assets/icons/logo_white.svg" alt="Almep Trading" width="126" height="31" />
        </a>
        <button class="header__mobile-search-close" id="mobileSearchClose" aria-label="Закрыть">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M18 6L6 18M6 6L18 18" stroke="#000000" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div class="header__mobile-search-bar">
        <input
          type="text"
          class="header__mobile-search-input"
          id="mobileSearchInput"
          placeholder={t.header.search_placeholder}
        />
        <button class="header__mobile-search-submit" aria-label="Поиск">
          <img src="/assets/icons/search.svg" alt="Поиск" width="25" height="25" />
        </button>
      </div>

      <div class="header__mobile-search-results" id="mobileSearchResults"></div>
    </div>

    <!-- Десктопный хедер -->
    <div class="header__top">
      <div class="header__left">
        <a href={`/${lang}`} class="header__logo">
          <img src="/assets/icons/logo.svg" alt="Almep Trading" width="162" height="56" />
        </a>
        <a href={`/${lang}/products`} class="header__catalog-btn">
          {t.header.catalog}
        </a>
      </div>

      <div class="header__right">
        <!-- Поиск -->
        <div class="header__search" id="headerSearch">
          <div class="header__search-trigger">
            <img src="/assets/icons/search.svg" alt="Поиск" width="25" height="25" />
          </div>

          <div class="header__search-dropdown">
            <div class="header__search-input-wrapper">
              <input
                type="text"
                class="header__search-input"
                placeholder={t.header.search_placeholder}
                id="searchInput"
              />
              <button class="header__search-submit" aria-label="Поиск">
                <img src="/assets/icons/search.svg" alt="Поиск" width="25" height="25" />
              </button>
            </div>

            <div class="header__search-divider"></div>

            <div class="header__search-results" id="searchResults">
              <!-- Результаты поиска будут добавлены динамически -->
            </div>
          </div>
        </div>

        <!-- Языковой переключатель -->
        <div class="header__lang" id="langSwitcher">
          <div class="header__lang-trigger">
            <img src="/assets/icons/globe.svg" alt="Язык" width="28" height="28" />
            <span class="header__lang-current">{currentLangLabel}</span>
            <svg class="header__lang-arrow" width="15" height="8" viewBox="0 0 15 8" fill="none">
              <path d="M1 1L7.5 7L14 1" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>

          <div class="header__lang-dropdown">
            <div class="header__lang-dropdown-top">
              <img src="/assets/icons/globe.svg" alt="Язык" width="28" height="28" />
              <span class="header__lang-dropdown-label">{currentLangLabel}</span>
              <svg width="15" height="8" viewBox="0 0 15 8" fill="none">
                <path d="M1 1L7.5 7L14 1" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>

            <div class="header__lang-divider"></div>

            <ul class="header__lang-list">
              {otherLangs.map(l => (
                <li>
                  <a 
                    href={`/${l.code}${pathWithoutLang}`}
                    class="header__lang-option"
                    data-lang={l.code}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <a href={`tel:${t.header.phone.replace(/\s/g, '')}`} class="header__phone">
          {t.header.phone}
        </a>
      </div>
    </div>

    <div class="header__bottom">
      <Nav links={navLinks} />
      <div class="header__socials">
        <a href="https://www.instagram.com/almepengineeringgroup/" class="header__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <img src="/assets/icons/instagram.svg" alt="Instagram" width="30" height="30" />
        </a>
        <a href="#" class="header__social-link" aria-label="YouTube">
          <img src="/assets/icons/youtube.svg" alt="YouTube" width="37" height="37" />
        </a>
        <a href="https://www.facebook.com/p/Almep-Engineering-Group-100076404414859/" class="header__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
          <img src="/assets/icons/facebook.svg" alt="Facebook" width="32" height="32" />
        </a>
      </div>
    </div>
  </div>
</header>

