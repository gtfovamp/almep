<script>
  // === MOBILE SEARCH ===
  function initMobileSearch() {
    const toggleBtn = document.getElementById('mobileSearchToggle');
    const closeBtn = document.getElementById('mobileSearchClose');
    const panel = document.getElementById('mobileSearchPanel');
    const input = document.getElementById('mobileSearchInput');
    const results = document.getElementById('mobileSearchResults');

    if (!toggleBtn || !closeBtn || !panel || !input || !results) return;

    // Открыть панель
    toggleBtn.addEventListener('click', () => {
      panel.classList.add('is-open');
      setTimeout(() => input.focus(), 150);
    });

    // Закрыть панель
    closeBtn.addEventListener('click', () => {
      panel.classList.remove('is-open');
      input.value = '';
      results.innerHTML = '';
    });

    // Поиск при вводе
    let searchTimeout;
    input.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      const query = e.target.value.trim();

      if (query.length < 2) {
        results.innerHTML = '';
        return;
      }

      searchTimeout = setTimeout(async () => {
        try {
          const response = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
          const data = await response.json();

          if (data.results && data.results.length > 0) {
            results.innerHTML = data.results.map((item) => `
              <a href="${item.url}" class="header__mobile-search-result-item">
                <img
                  src="${item.image || '/assets/placeholder.png'}"
                  alt="${item.title}"
                  class="header__mobile-search-result-image"
                />
                <span class="header__mobile-search-result-title">${item.title}</span>
              </a>
            `).join('');
          } else {
            results.innerHTML = '<div style="font-family: Montserrat; font-size: 14px; color: #636363; padding: 10px 0;">Ничего не найдено</div>';
          }
        } catch (error) {
          console.error('Mobile search error:', error);
          results.innerHTML = '';
        }
      }, 300);
    });
  }

  // === SEARCH ===
  function initSearch() {
    const searchContainer = document.getElementById('headerSearch');
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');

    if (!searchContainer || !searchInput || !searchResults) return;

    // Открытие/закрытие поиска
    searchContainer.addEventListener('click', (e) => {
      e.stopPropagation();
      searchContainer.classList.toggle('is-open');
      if (searchContainer.classList.contains('is-open')) {
        setTimeout(() => searchInput.focus(), 100);
      }
    });

    // Закрытие при клике вне
    document.addEventListener('click', () => {
      searchContainer.classList.remove('is-open');
    });

    // Поиск при вводе
    let searchTimeout;
    searchInput.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      const query = e.target.value.trim();

      if (query.length < 2) {
        searchResults.innerHTML = '';
        return;
      }

      searchTimeout = setTimeout(async () => {
        try {
          const response = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
          const data = await response.json();

          if (data.results && data.results.length > 0) {
            searchResults.innerHTML = data.results.map((item) => `
              <a href="${item.url}" class="header__search-result-item">
                <img src="${item.image || '/assets/placeholder.png'}" alt="${item.title}" class="header__search-result-image" />
                <span class="header__search-result-title">${item.title}</span>
              </a>
            `).join('');
          } else {
            searchResults.innerHTML = '<div style="padding: 20px; text-align: center; color: #636363;">Ничего не найдено</div>';
          }
        } catch (error) {
          console.error('Search error:', error);
          searchResults.innerHTML = '';
        }
      }, 300);
    });
  }

  // === LANGUAGE SWITCHER ===
  function initLangSwitcher() {
    const langSwitcher = document.getElementById('langSwitcher');

    if (!langSwitcher) return;

    langSwitcher.addEventListener('click', (e) => {
      e.stopPropagation();
      langSwitcher.classList.toggle('is-open');
    });

    document.addEventListener('click', () => {
      langSwitcher.classList.remove('is-open');
    });
  }

  // === MOBILE MENU ===
  function initMobileMenu() {
    const menuToggle = document.getElementById('mobileMenuToggle');

    if (!menuToggle) return;

    menuToggle.addEventListener('click', () => {
      menuToggle.classList.toggle('is-open');
      // Здесь будет логика открытия мобильного меню
    });
  }

  // Инициализация
  initSearch();
  initLangSwitcher();
  initMobileMenu();
  initMobileSearch();

  // Переинициализация после View Transition
  document.addEventListener('astro:page-load', () => {
    initSearch();
    initLangSwitcher();
    initMobileMenu();
    initMobileSearch();
  });
</script>