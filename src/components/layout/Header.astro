---
import Nav from './Nav.astro';
import { getLangLabel, type Lang } from '../../utils/i18n';

interface Props {
  t: any;
  lang: Lang;
}

const { t, lang } = Astro.props;

const currentPath = new URL(Astro.request.url).pathname;
const pathWithoutLang = currentPath.replace(/^\/(ru|en|az)/, '') || '/';

const navLinks = [
  { label: t.nav.home, href: `/${lang}`, active: pathWithoutLang === '/' },
  { label: t.nav.about, href: `/${lang}/about`, dropdown: true },
  { label: t.nav.services, href: `/${lang}/services` },
  { label: t.nav.products, href: `/${lang}/products` },
  { label: t.nav.partners, href: `/${lang}/partners` },
  { label: t.nav.portfolio, href: `/${lang}/portfolio` },
  { label: t.nav.news, href: `/${lang}/news` },
  { label: t.nav.reviews, href: `/${lang}/reviews` },
  { label: t.nav.contacts, href: `/${lang}/contacts` },
];

const currentLangLabel = getLangLabel(lang);
const otherLangs = [
  { code: 'ru', label: 'RU' },
  { code: 'en', label: 'EN' },
  { code: 'az', label: 'AZ' },
].filter(l => l.code !== lang);
---

<header class="header">
  <div class="header__inner">
    <div class="header__top">
      <div class="header__left">
        <a href={`/${lang}`} class="header__logo">
          <img src="/assets/icons/logo.svg" alt="Almep Trading" width="162" height="56" />
        </a>
        <a href={`/${lang}/products`} class="header__catalog-btn">
          {t.header.catalog}
        </a>
      </div>

      <div class="header__right">
        <button class="header__search" aria-label="Поиск">
          <img src="/assets/icons/search.svg" alt="Поиск" width="28" height="28" />
        </button>

        <!-- Языковой переключатель -->
        <div class="header__lang" id="langSwitcher">
          <div class="header__lang-trigger">
            <img src="/assets/icons/globe.svg" alt="Язык" width="28" height="28" />
            <span class="header__lang-current">{currentLangLabel}</span>
            <svg class="header__lang-arrow" width="15" height="8" viewBox="0 0 15 8" fill="none">
              <path d="M1 1L7.5 7L14 1" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>

          <div class="header__lang-dropdown">
            <div class="header__lang-dropdown-top">
              <img src="/assets/icons/globe.svg" alt="Язык" width="28" height="28" />
              <span class="header__lang-dropdown-label">{currentLangLabel}</span>
              <svg width="15" height="8" viewBox="0 0 15 8" fill="none">
                <path d="M1 1L7.5 7L14 1" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>

            <div class="header__lang-divider"></div>

            <ul class="header__lang-list">
              {otherLangs.map(l => (
                <li>
                  <a 
                    href={`/${l.code}${pathWithoutLang}`}
                    class="header__lang-option"
                    data-lang={l.code}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <a href={`tel:${t.header.phone.replace(/\s/g, '')}`} class="header__phone">
          {t.header.phone}
        </a>
      </div>
    </div>

    <div class="header__bottom">
      <Nav links={navLinks} />
      <div class="header__socials">
        <a href="#" class="header__social-link" aria-label="Instagram">
          <img src="/assets/icons/instagram.svg" alt="Instagram" width="30" height="30" />
        </a>
        <a href="#" class="header__social-link" aria-label="YouTube">
          <img src="/assets/icons/youtube.svg" alt="YouTube" width="37" height="37" />
        </a>
        <a href="#" class="header__social-link" aria-label="Facebook">
          <img src="/assets/icons/facebook.svg" alt="Facebook" width="32" height="32" />
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    position: absolute;
    top: 35px;
    left: 50%;
    transform: translateX(-50%);
    width: 1410px;
    z-index: 100;
  }

  .header__inner {
    display: flex;
    flex-direction: column;
    gap: 33px;
  }

  .header__top {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 56px;
  }

  .header__left {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 31px;
  }

  .header__logo img {
    display: block;
    width: 162px;
    height: 56px;
    object-fit: contain;
  }

  .header__catalog-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 164px;
    height: 50px;
    background: #1C508F;
    border-radius: 2px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    color: #FFFFFF;
    transition: background 0.2s;
  }

  .header__catalog-btn:hover {
    background: #174480;
  }

  .header__right {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 20px;
  }

  .header__search {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    cursor: pointer;
    background: none;
    border: none;
  }

  .header__search img {
    width: 28px;
    height: 28px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .header__lang {
    position: relative;
    cursor: pointer;
  }

  .header__lang-trigger {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    height: 28px;
  }

  .header__lang-trigger img {
    width: 28px;
    height: 28px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .header__lang-current {
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    color: #FFFFFF;
  }

  .header__lang-arrow {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .header__lang-dropdown {
    position: absolute;
    top: 0;
    right: 0;
    width: 160px;
    background: #FFFFFF;
    box-shadow: 0px 4px 4px rgba(0, 0, 0, 0.25);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 300;
  }

  .header__lang.is-open .header__lang-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .header__lang.is-open .header__lang-arrow {
    transform: rotate(180deg);
  }

  .header__lang-dropdown-top {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    padding: 14px 17px 0;
  }

  .header__lang-dropdown-top img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .header__lang-dropdown-label {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    color: #000000;
  }

  .header__lang-divider {
    width: 86px;
    height: 1px;
    background: rgba(0, 0, 0, 0.3);
    margin: 10px auto 0;
  }

  .header__lang-list {
    list-style: none;
    padding: 11px 0 16px;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 11px;
  }

  .header__lang-option {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    text-align: center;
    color: #636363;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    width: 28px;
    transition: color 0.15s;
    text-decoration: none;
    display: block;
  }

  .header__lang-option:hover {
    color: #1C508F;
  }

  .header__phone {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 16px;
    line-height: 110%;
    color: #FFFFFF;
    white-space: nowrap;
  }

  .header__bottom {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 37px;
  }

  .header__socials {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 15px;
  }

  .header__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header__social-link img {
    object-fit: contain;
    filter: brightness(0) invert(1);
    transition: opacity 0.2s;
  }

  .header__social-link:hover img {
    opacity: 0.75;
  }
</style>

<script>
  const langSwitcher = document.getElementById('langSwitcher');

  // Открыть/закрыть дропдаун
  langSwitcher?.addEventListener('click', (e) => {
    e.stopPropagation();
    langSwitcher.classList.toggle('is-open');
  });

  // Закрыть при клике вне
  document.addEventListener('click', () => {
    langSwitcher?.classList.remove('is-open');
  });
  
  // Переинициализация после View Transition
  document.addEventListener('astro:page-load', () => {
    const switcher = document.getElementById('langSwitcher');
    switcher?.addEventListener('click', (e) => {
      e.stopPropagation();
      switcher.classList.toggle('is-open');
    });
  });
</script>