---
import type { Lang } from '../../utils/i18n';

interface Props {
  t: any;
  lang: Lang;
}

const { t } = Astro.props;

const features = [
  {
    icon: '/assets/icons/briefcase.svg',
    title: t.features.professional_title,
    text: t.features.professional_text,
  },
  {
    icon: '/assets/icons/problem-solving-skills.svg',
    title: t.features.solutions_title,
    text: t.features.solutions_text,
  },
  {
    icon: '/assets/icons/structure.svg',
    title: t.features.integrated_title,
    text: t.features.integrated_text,
  },
];
---

<section class="features">
  <div class="features__inner">
    {features.map((item) => (
      <div class="features__card">
        <div class="features__icon-wrap">
          <img src={item.icon} alt={item.title} width="57" height="57" />
        </div>
        <h3 class="features__title">{item.title}</h3>
        <p class="features__text">{item.text}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .features {
    width: 100%;
    background: #FFFFFF;
    padding: 55px 0 55px;
  }

  .features__inner {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 37px;
    width: 1410px;
    margin: 0 auto;
  }

  /* === Карточка === */
  .features__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    flex: 1;
    text-align: center;
  }

  /* === Иконка === */
  .features__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 90px;
    height: 90px;
    background: #FFFFFF;
    box-shadow: 0px 0px 4px rgba(0, 0, 0, 0.3);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .features__icon-wrap img {
    width: 57px;
    height: 57px;
    object-fit: contain;
    /* Иконки синие по дизайну */
  }

  /* === Заголовок === */
  .features__title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 30px;
    line-height: 110%;
    letter-spacing: -0.01em;
    color: #000000;
    text-align: center;
  }

  /* === Текст === */
  .features__text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #000000;
    text-align: center;
  }

  /* === МОБИЛЬНАЯ ВЕРСИЯ === */
  @media (max-width: 768px) {
    .features {
      padding: 45px 0;
    }

    .features__inner {
      flex-direction: column;
      width: 100%;
      padding: 0 23px;
      gap: 30px;
    }

    .features__card {
      gap: 25px;
    }

    .features__icon-wrap {
      width: 90px;
      height: 90px;
      box-shadow: 0px 0px 3.91111px rgba(0, 0, 0, 0.3);
      border-radius: 57.2px;
    }

    .features__title {
      font-size: 20px;
      line-height: 110%;
    }

    .features__text {
      font-size: 16px;
      line-height: 130%;
    }
  }
</style>