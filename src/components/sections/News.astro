---
import type { Lang } from '../../utils/i18n';
import { env } from 'cloudflare:workers';
import { timeAgo } from '../../lib/time-helpers';

interface Props {
  t: any;
  lang: Lang;
}

const { t, lang } = Astro.props;

export const prerender = false;

// Функция для подсчета времени чтения
function calculateReadTime(blocks: any[], lang: Lang): number {
  let totalWords = 0;

  blocks.forEach((block: any) => {
    if (block.type === 'text' || block.type === 'heading') {
      const text = block.data?.[`text_${lang}`] || block.data?.text_ru || '';
      // Считаем слова (примерно)
      const words = text.trim().split(/\s+/).filter((w: string) => w.length > 0);
      totalWords += words.length;
    }
  });

  // Средняя скорость чтения: 200 слов в минуту
  const minutes = Math.ceil(totalWords / 200);
  return minutes > 0 ? minutes : 1;
}

// Функция для форматирования времени чтения
function formatReadTime(minutes: number, lang: Lang, t: any): string {
  if (lang === 'ru') {
    if (minutes === 1) return '1 минута';
    if (minutes >= 2 && minutes <= 4) return `${minutes} минуты`;
    return `${minutes} минут`;
  } else if (lang === 'en') {
    return minutes === 1 ? '1 minute' : `${minutes} minutes`;
  } else { // az
    return `${minutes} dəqiqə`;
  }
}

// Загружаем новости из базы данных
let newsItems = [];
try {
  const db = env.DB;
  if (db) {
    const { results } = await db.prepare(
      'SELECT * FROM news ORDER BY published_at DESC LIMIT 9'
    ).all();

    newsItems = results.map((item: any) => {
      // Парсим блоки контента
      let blocks = [];
      try {
        blocks = JSON.parse(item.blocks);
      } catch (e) {
        console.error('Failed to parse blocks:', e);
      }

      // Получаем первый текстовый блок как excerpt
      const textBlock = blocks.find((b: any) => b.type === 'text');
      const excerptText = textBlock?.data?.[`text_${lang}`] || textBlock?.data?.text_ru || '';
      const excerpt = excerptText.substring(0, 150) + (excerptText.length > 150 ? '...' : '');

      // Получаем заголовок на нужном языке
      const title = item[`title_${lang}`] || item.title;

      // Рассчитываем время чтения
      const readTime = calculateReadTime(blocks, lang);

      return {
        id: item.id,
        title,
        excerpt,
        image: item.cover_image_url,
        link: `/${lang}/news/${item.id}`,
        category: t.news.category_company,
        date: new Date(item.published_at).toLocaleDateString(lang === 'ru' ? 'ru-RU' : lang === 'en' ? 'en-US' : 'az-AZ'),
        timeAgo: timeAgo(item.published_at, lang),
        readTime: readTime.toString(),
        readTimeFormatted: formatReadTime(readTime, lang, t)
      };
    });
  }
} catch (error) {
  console.error('Error fetching news:', error);
}

// Если новостей нет, показываем заглушку
if (newsItems.length === 0) {
  newsItems = t.news.items.map((item: any, index: number) => ({
    ...item,
    image: `/assets/images/news-${(index % 3) + 1}.png`,
    link: `/${lang}/news/${index + 1}`,
    category: t.news.category_company,
    readTimeFormatted: `${item.readTime} ${item.readTime === '1' ? t.news.minute : t.news.minutes}`
  }));
}

// Разбиваем по 3 карточки на слайд
const slides = [];
for (let i = 0; i < newsItems.length; i += 3) {
  slides.push(newsItems.slice(i, i + 3));
}
---

<section class="news">
  <div class="news__inner">

    <h2 class="news__title">{t.news.title}</h2>

    <div class="news__slider-wrap">

      <div class="news__slider" id="newsSlider">
        {slides.map((slide, slideIndex) => (
          <div class={`news__slide ${slideIndex === 0 ? 'news__slide--active' : ''}`}>
            <div class="news__grid">
              {slide.map((item: any) => (
                <div class="news__card">

                  <!-- Картинка -->
                  <div class="news__card-img-wrap">
                    <img
                      src={item.image}
                      alt={item.title}
                      class="news__card-img"
                    />
                  </div>

                  <!-- Контент -->
                  <div class="news__card-body">

                    <div class="news__card-meta-wrap">

                      <!-- Категория -->
                      <div class="news__card-category">
                        <span class="news__card-category-text">{item.category}</span>
                      </div>

                      <!-- Дата и время публикации -->
                      <div class="news__card-meta">
                        <div class="news__card-date">
                          <img src="/assets/icons/calendar.svg" alt={t.news.date_alt} class="news__card-icon" width="28" height="28" />
                          <span class="news__card-meta-text">{item.date}</span>
                        </div>
                        <div class="news__card-time">
                          <img src="/assets/icons/time.svg" alt={t.news.time_alt} class="news__card-icon" width="29" height="29" />
                          <span class="news__card-meta-text">{item.timeAgo}</span>
                        </div>
                      </div>

                    </div>

                    <!-- Текст -->
                    <div class="news__card-content">
                      <h3 class="news__card-title">{item.title}</h3>
                      <p class="news__card-excerpt">{item.excerpt}</p>
                    </div>

                    <!-- Ссылка -->
                    <a href={item.link} class="news__card-link">
                      {t.news.learn_more}
                      <svg width="27" height="20" viewBox="0 0 27 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0.013702 10.394L26.1767 9.68691M26.1767 9.68691L16.8428 0.353097M26.1767 9.68691L16.9401 18.9235" stroke="#1C508F"/>
                      </svg>
                    </a>

                  </div>

                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Стрелка вправо -->
      <button class="news__arrow news__arrow--right" id="newsArrowRight" aria-label={t.news.aria_next}>
        <svg width="23" height="30" viewBox="0 0 23 30" fill="none">
          <path d="M3 3L20 15L3 27" stroke="#000000" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Стрелка влево -->
      <button class="news__arrow news__arrow--left" id="newsArrowLeft" aria-label={t.news.aria_prev}>
        <svg width="23" height="30" viewBox="0 0 23 30" fill="none">
          <path d="M20 3L3 15L20 27" stroke="#000000" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>

    <!-- Нижняя панель: точки + ссылка -->
    <div class="news__bottom">

      <div class="news__dots" id="newsDots">
        {slides.map((_, i) => (
          <button
            class={`news__dot ${i === 0 ? 'news__dot--active' : ''}`}
            data-index={i}
            aria-label={`${t.news.aria_slide} ${i + 1}`}
          />
        ))}
      </div>

      <a href={`/${lang}/news`} class="news__more">
        {t.news.read_news}
        <svg width="27" height="20" viewBox="0 0 27 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0.013702 10.394L26.1767 9.68691M26.1767 9.68691L16.8428 0.353097M26.1767 9.68691L16.9401 18.9235" stroke="#000000"/>
        </svg>
      </a>

      <div class="news__scrollbar" id="newsScrollbar">
        <div class="news__scrollbar-track"></div>
        <div class="news__scrollbar-thumb" id="newsScrollbarThumb"></div>
      </div>

    </div>

    <!-- Кнопка консультации (только на мобилке) -->
    <div class="news__cta">
      <a href={`/${lang}/contacts`} class="news__btn">{t.news.btn_consultation}</a>
    </div>

  </div>

</section>

<style>
  /* ===== Секция ===== */
  .news {
    width: 100%;
    background: #FFFFFF;
    padding: 55px 0 110px;
  }

  .news__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 60px;
    width: 1455px;
    margin: 0 auto;
  }

  /* ===== Заголовок ===== */
  .news__title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 48px;
    line-height: 110%;
    color: #000000;
    width: 100%;
    margin: 0;
  }

  /* ===== Слайдер ===== */
  .news__slider-wrap {
    position: relative;
    width: 1410px;
  }

  .news__slider {
    width: 100%;
    overflow: hidden;
  }

  .news__slide {
    display: none;
  }

  .news__slide--active {
    display: block;
  }

  /* ===== Сетка карточек ===== */
  .news__grid {
    display: grid;
    grid-template-columns: repeat(3, 450px);
    gap: 30px;
    padding: 10px;
  }

  /* ===== Карточка ===== */
  .news__card {
    display: flex;
    flex-direction: column;
    width: 450px;
    min-height: 672px;
    background: #FFFFFF;
    box-shadow: 0px 0px 4px rgba(0, 0, 0, 0.3);
    border-radius: 7px;
    overflow: hidden;
  }

  /* ===== Картинка ===== */
  .news__card-img-wrap {
    width: 100%;
    height: 300px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .news__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .news__card:hover .news__card-img {
    transform: scale(1.03);
  }

  /* ===== Тело карточки ===== */
  .news__card-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 25px 30px;
    flex: 1;
  }

  /* ===== Мета-обёртка ===== */
  .news__card-meta-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 15px;
    width: 100%;
  }

  /* ===== Категория ===== */
  .news__card-category {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 175px;
    height: 41px;
    background: #A4C5EE;
    border-radius: 17px;
    flex-shrink: 0;
  }

  .news__card-category-text {
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    color: #003F8D;
  }

  /* ===== Дата + время ===== */
  .news__card-meta {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .news__card-date,
  .news__card-time {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 13px;
  }

  .news__card-icon {
    flex-shrink: 0;
    object-fit: contain;
  }

  .news__card-meta-text {
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 110%;
    color: #676767;
    white-space: nowrap;
  }

  /* ===== Контент ===== */
  .news__card-content {
    display: flex;
    flex-direction: column;
    gap: 3px;
    width: 100%;
  }

  .news__card-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 20px;
    line-height: 110%;
    letter-spacing: -0.01em;
    color: #000000;
    margin: 0;
  }

  .news__card-excerpt {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #000000;
    margin: 0;
  }

  /* ===== Ссылка "Узнать больше" ===== */
  .news__card-link {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 11px;
    font-family: 'Raleway', sans-serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 110%;
    color: #1C508F;
    text-decoration: none;
    margin-top: auto;
    transition: opacity 0.2s ease;
  }

  .news__card-link:hover {
    opacity: 0.75;
  }

  .news__card-link svg {
    flex-shrink: 0;
  }

  /* ===== Стрелки ===== */
  .news__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 76px;
    height: 76px;
    background: #F1F1F1;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
    z-index: 10;
  }

  .news__arrow:hover {
    background: #E0E0E0;
  }

  .news__arrow--right {
    right: -38px;
  }

  .news__arrow--left {
    left: -38px;
  }

  .news__arrow--left.is-hidden,
  .news__arrow--right.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* ===== Нижняя панель ===== */
  .news__bottom {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 1410px;
    position: relative;
  }

  /* ===== Точки ===== */
  .news__dots {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .news__dot {
    width: 17px;
    height: 17px;
    border-radius: 50%;
    border: none;
    background: #D9D9D9;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;
  }

  .news__dot--active {
    background: #1C508F;
  }

  /* ===== Ссылка "Читать новости" ===== */
  .news__more {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 11px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 24px;
    line-height: 110%;
    color: #1C508F;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .news__more:hover {
    opacity: 0.75;
  }

  .news__more svg {
    flex-shrink: 0;
  }

  /* Кнопка консультации (скрыта на десктопе) */
  .news__cta {
    display: none;
  }

  /* === МОБИЛЬНАЯ ВЕРСИЯ === */
  @media (max-width: 768px) {
    .news {
      padding: 45px 0;
    }

    .news__inner {
      width: 100%;
      padding: 0 23px;
      gap: 45px;
    }

    .news__title {
      font-size: 24px;
      line-height: 110%;
    }

    .news__slider-wrap {
      width: 100%;
      overflow: visible;
    }

    .news__slider {
      overflow: visible;
    }

    .news__slide {
      display: none;
    }

    .news__slide--active {
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .news__slide--active::-webkit-scrollbar {
      display: none;
    }

    .news__grid {
      display: flex;
      flex-direction: row;
      gap: 15px;
      grid-template-columns: none;
      padding: 0;
    }

    .news__card {
      width: 274px;
      min-height: 684px;
      flex-shrink: 0;
      scroll-snap-align: start;
    }

    .news__card-img-wrap {
      height: 300px;
    }

    .news__card-body {
      padding: 20px 15px;
      gap: 19px;
    }

    .news__card-meta-wrap {
      gap: 15px;
    }

    .news__card-category {
      width: 161px;
      height: 37.72px;
      border-radius: 15.64px;
    }

    .news__card-category-text {
      font-size: 14.72px;
      line-height: 110%;
    }

    .news__card-meta {
      gap: 15px;
      flex-wrap: wrap;
    }

    .news__card-date,
    .news__card-time {
      gap: 10px;
    }

    .news__card-icon {
      width: 25px;
      height: 25px;
    }

    .news__card-meta-text {
      font-size: 16px;
      line-height: 110%;
    }

    .news__card-content {
      gap: 25px;
    }

    .news__card-title {
      font-size: 18px;
      line-height: 130%;
    }

    .news__card-excerpt {
      font-size: 16px;
      line-height: 130%;
    }

    .news__card-link {
      font-size: 16px;
      line-height: 130%;
      gap: 11px;
    }

    .news__card-link svg {
      width: 18.5px;
      height: 13.44px;
    }

    .news__card-link svg path {
      stroke: #1C508F;
    }

    .news__arrow {
      display: none;
    }

    .news__bottom {
      width: 100%;
      flex-direction: column;
      gap: 35px;
      align-items: flex-end;
    }

    .news__scrollbar {
      display: block;
      position: relative;
      width: 100%;
      height: 13px;
      order: 1;
    }

    .news__scrollbar-track {
      position: absolute;
      width: 100%;
      height: 7px;
      left: 0;
      top: 3px;
      background: #C0C0C0;
      border-radius: 100px;
    }

    .news__scrollbar-thumb {
      position: absolute;
      width: 94px;
      height: 13px;
      left: 0;
      top: 0;
      background: #1C508F;
      border-radius: 100px;
      cursor: pointer;
      transition: left 0.1s ease-out;
    }

    .news__dots {
      display: none;
    }

    .news__more {
      font-size: 16px;
      line-height: 130%;
      order: 0;
      flex-shrink: 0;
      color: #000000;
    }

    .news__more svg {
      width: 12.73px;
      height: 13.44px;
    }

    .news__more svg path {
      stroke: #000000;
    }

    .news__cta {
      display: block;
      width: 100%;
    }

    .news__btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 85px;
      background: #1C508F;
      box-shadow: 0px 0px 4px rgba(0, 0, 0, 0.3);
      border-radius: 9px;
      font-family: 'Montserrat', sans-serif;
      font-weight: 400;
      font-size: 16px;
      line-height: 130%;
      letter-spacing: -0.01em;
      color: #FFFFFF;
      text-decoration: none;
      transition: background 0.2s ease;
    }

    .news__btn:hover {
      background: #174480;
    }
  }
</style>

<script>
  const newsSlides = document.querySelectorAll('.news__slide');
  const newsDots   = document.querySelectorAll('.news__dot');
  const newsArrowRight = document.getElementById('newsArrowRight');
  const newsArrowLeft  = document.getElementById('newsArrowLeft');

  let newsCurrent = 0;
  const newsTotal = newsSlides.length;

  function newsGoTo(index: number) {
    newsSlides[newsCurrent].classList.remove('news__slide--active');
    newsDots[newsCurrent].classList.remove('news__dot--active');

    newsCurrent = index;

    newsSlides[newsCurrent].classList.add('news__slide--active');
    newsDots[newsCurrent].classList.add('news__dot--active');

    newsArrowLeft?.classList.toggle('is-hidden', newsCurrent === 0);
    newsArrowRight?.classList.toggle('is-hidden', newsCurrent === newsTotal - 1);
  }

  // Инициализация
  newsArrowLeft?.classList.add('is-hidden');
  if (newsTotal <= 1) newsArrowRight?.classList.add('is-hidden');

  newsArrowRight?.addEventListener('click', () => {
    if (newsCurrent < newsTotal - 1) newsGoTo(newsCurrent + 1);
  });

  newsArrowLeft?.addEventListener('click', () => {
    if (newsCurrent > 0) newsGoTo(newsCurrent - 1);
  });

  newsDots.forEach((dot, i) => {
    dot.addEventListener('click', () => newsGoTo(i));
  });

  // Мобильный скроллбар для News
  function initNewsScrollbar() {
    if (window.innerWidth > 768) return;

    const activeSlide = document.querySelector('.news__slide--active') as HTMLElement;
    const scrollbarThumb = document.getElementById('newsScrollbarThumb') as HTMLElement;
    const scrollbar = document.getElementById('newsScrollbar') as HTMLElement;

    if (!activeSlide || !scrollbarThumb || !scrollbar) return;

    function updateThumbPosition() {
      const scrollLeft = activeSlide.scrollLeft;
      const scrollWidth = activeSlide.scrollWidth;
      const clientWidth = activeSlide.clientWidth;

      if (scrollWidth <= clientWidth) return;

      const scrollableWidth = scrollWidth - clientWidth;
      const scrollbarWidth = scrollbar.clientWidth;
      const thumbWidth = scrollbarThumb.clientWidth;
      const maxThumbPosition = scrollbarWidth - thumbWidth;

      const thumbPosition = (scrollLeft / scrollableWidth) * maxThumbPosition;
      scrollbarThumb.style.left = `${thumbPosition}px`;
    }

    // Синхронизация при скролле контента
    activeSlide.addEventListener('scroll', updateThumbPosition);

    // Драг скроллбара
    let isDragging = false;
    let startX = 0;
    let startLeft = 0;

    scrollbarThumb.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      startLeft = parseInt(scrollbarThumb.style.left || '0');
      e.preventDefault();
    });

    scrollbarThumb.addEventListener('touchstart', (e) => {
      isDragging = true;
      startX = e.touches[0].clientX;
      startLeft = parseInt(scrollbarThumb.style.left || '0');
      e.preventDefault();
    });

    const handleMove = (clientX: number) => {
      if (!isDragging) return;

      const deltaX = clientX - startX;
      const scrollbarWidth = scrollbar.clientWidth;
      const thumbWidth = scrollbarThumb.clientWidth;
      const maxThumbPosition = scrollbarWidth - thumbWidth;

      let newLeft = startLeft + deltaX;
      newLeft = Math.max(0, Math.min(newLeft, maxThumbPosition));

      const scrollWidth = activeSlide.scrollWidth;
      const clientWidth = activeSlide.clientWidth;
      const scrollableWidth = scrollWidth - clientWidth;

      const scrollPosition = (newLeft / maxThumbPosition) * scrollableWidth;
      activeSlide.scrollLeft = scrollPosition;
    };

    document.addEventListener('mousemove', (e) => handleMove(e.clientX));
    document.addEventListener('touchmove', (e) => handleMove(e.touches[0].clientX));

    document.addEventListener('mouseup', () => {
      isDragging = false;
    });

    document.addEventListener('touchend', () => {
      isDragging = false;
    });

    // Клик по треку
    scrollbar.addEventListener('click', (e) => {
      if (e.target === scrollbarThumb) return;

      const rect = scrollbar.getBoundingClientRect();
      const clickX = e.clientX - rect.left;
      const thumbWidth = scrollbarThumb.clientWidth;
      const scrollbarWidth = scrollbar.clientWidth;
      const maxThumbPosition = scrollbarWidth - thumbWidth;

      const newLeft = Math.max(0, Math.min(clickX - thumbWidth / 2, maxThumbPosition));

      const scrollWidth = activeSlide.scrollWidth;
      const clientWidth = activeSlide.clientWidth;
      const scrollableWidth = scrollWidth - clientWidth;

      const scrollPosition = (newLeft / maxThumbPosition) * scrollableWidth;
      activeSlide.scrollLeft = scrollPosition;
    });

    updateThumbPosition();
  }

  initNewsScrollbar();

  window.addEventListener('resize', () => {
    initNewsScrollbar();
  });
</script>