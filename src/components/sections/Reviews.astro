---
import type { Lang } from '../../utils/i18n';
import { env } from 'cloudflare:workers';

interface Props {
  t: any;
  lang: Lang;
}

const { t, lang } = Astro.props;

// Получаем отзывы напрямую из базы данных
let reviews = [];
try {
  const db = env.DB;
  if (db) {
    const { results } = await db.prepare(
      'SELECT * FROM testimonials WHERE approved = 1 ORDER BY order_index ASC'
    ).all();

    reviews = (results || []).map((item: any) => ({
      text: item[`text_${lang}`] || item.text,
      author: item[`name_${lang}`] || item.name
    }));
  }
} catch (error) {
  console.error('Failed to fetch testimonials:', error);
}

// По 3 карточки на слайд
const slides = [];
for (let i = 0; i < reviews.length; i += 3) {
  slides.push(reviews.slice(i, i + 3));
}
---

<section class="reviews">
  <div class="reviews__inner">

    <h2 class="reviews__title">{t.reviews.title}</h2>

    <div class="reviews__slider-wrap">

      <div class="reviews__slider" id="reviewsSlider">
        {slides.map((slide, slideIndex) => (
          <div class={`reviews__slide ${slideIndex === 0 ? 'reviews__slide--active' : ''}`}>
            <div class="reviews__grid">
              {slide.map((item: any) => (
                <div class="reviews__card">

                  <!-- Кавычка -->
                  <span class="reviews__quote">&ldquo;</span>

                  <!-- Контент карточки -->
                  <div class="reviews__card-inner">

                    <div class="reviews__card-top">
                      <!-- Текст отзыва -->
                      <p class="reviews__card-text">{item.text}</p>
                      <!-- Линия -->
                      <hr class="reviews__card-line" />
                    </div>

                    <!-- Автор -->
                    <div class="reviews__card-author-wrap">
                      <span class="reviews__card-author">{item.author}</span>
                    </div>

                  </div>

                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Стрелка вправо -->
      <button class="reviews__arrow reviews__arrow--right" id="reviewsArrowRight" aria-label={t.reviews.aria_next}>
        <svg width="23" height="30" viewBox="0 0 23 30" fill="none">
          <path d="M3 3L20 15L3 27" stroke="#000000" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Стрелка влево -->
      <button class="reviews__arrow reviews__arrow--left" id="reviewsArrowLeft" aria-label={t.reviews.aria_prev}>
        <svg width="23" height="30" viewBox="0 0 23 30" fill="none">
          <path d="M20 3L3 15L20 27" stroke="#000000" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>

    <!-- Нижняя панель -->
    <div class="reviews__bottom">

      <div class="reviews__dots" id="reviewsDots">
        {slides.map((_, i) => (
          <button
            class={`reviews__dot ${i === 0 ? 'reviews__dot--active' : ''}`}
            data-index={i}
            aria-label={`${t.reviews.aria_slide} ${i + 1}`}
          />
        ))}
      </div>

      <a href={`/${lang}/reviews`} class="reviews__more">
        {t.reviews.all_reviews}
        <svg width="27" height="20" viewBox="0 0 27 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0.013702 10.394L26.1767 9.68691M26.1767 9.68691L16.8428 0.353097M26.1767 9.68691L16.9401 18.9235" stroke="#000000"/>
        </svg>
      </a>

      <div class="reviews__scrollbar" id="reviewsScrollbar">
        <div class="reviews__scrollbar-track"></div>
        <div class="reviews__scrollbar-thumb" id="reviewsScrollbarThumb"></div>
      </div>

    </div>

    <!-- Кнопка -->
    <a href={`/${lang}/contacts`} class="reviews__btn">{t.reviews.btn_consultation}</a>

  </div>
</section>

<style>
  /* ===== Секция ===== */
  .reviews {
    width: 100%;
    background: #FFFFFF;
    padding: 110px 0 110px;
  }

  .reviews__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 60px;
    width: 1469px;
    margin: 0 auto;
  }

  /* ===== Заголовок ===== */
  .reviews__title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 48px;
    line-height: 110%;
    color: #000000;
    width: 100%;
    margin: 0;
  }

  /* ===== Слайдер ===== */
  .reviews__slider-wrap {
    position: relative;
    width: 1410px;
  }

  .reviews__slider {
    width: 100%;
    overflow: hidden;
  }

  .reviews__slide {
    display: none;
  }

  .reviews__slide--active {
    display: block;
  }

  /* ===== Сетка ===== */
  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 450px);
    gap: 30px;
    padding: 10px;
  }

  /* ===== Карточка ===== */
  .reviews__card {
    position: relative;
    width: 450px;
    height: 420px;
    background: #FFFFFF;
    box-shadow: 0px 0px 4px rgba(0, 0, 0, 0.3);
    border-radius: 7px;
    box-sizing: border-box;
  }

  /* ===== Большая кавычка ===== */
  .reviews__quote {
    position: absolute;
    left: 25px;
    top: 25px;
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 128px;
    line-height: 110%;
    color: #000000;
    user-select: none;
    pointer-events: none;
  }

  /* ===== Внутренний контейнер ===== */
  .reviews__card-inner {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
    width: 400px;
    height: 271px;
    left: 25px;
    top: 116px;
  }

  /* ===== Верхняя часть: текст + линия ===== */
  .reviews__card-top {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    width: 400px;
    height: 223px;
    flex: none;
  }

  /* ===== Текст отзыва ===== */
  .reviews__card-text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #000000;
    margin: 0;
    width: 400px;
  }

  /* ===== Линия ===== */
  .reviews__card-line {
    width: 400px;
    border: none;
    border-top: 1px solid #000000;
    margin: 0;
    align-self: stretch;
  }

  /* ===== Автор ===== */
  .reviews__card-author-wrap {
    width: 400px;
    height: 26px;
  }

  .reviews__card-author {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 110%;
    letter-spacing: -0.01em;
    color: #000000;
    width: 400px;
    height: 26px;
  }

  /* ===== Стрелки ===== */
  .reviews__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 76px;
    height: 76px;
    background: #F1F1F1;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
    z-index: 10;
  }

  .reviews__arrow:hover {
    background: #E0E0E0;
  }

  .reviews__arrow--right {
    right: -38px;
  }

  .reviews__arrow--left {
    left: -38px;
  }

  .reviews__arrow--left.is-hidden,
  .reviews__arrow--right.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* ===== Нижняя панель ===== */
  .reviews__bottom {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 1410px;
    position: relative;
  }

  /* ===== Точки ===== */
  .reviews__dots {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .reviews__dot {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    border: none;
    background: #D9D9D9;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;
  }

  .reviews__dot--active {
    width: 17px;
    height: 17px;
    background: #1C508F;
  }

  /* ===== Ссылка "Все отзывы" ===== */
  .reviews__more {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 11px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 24px;
    line-height: 110%;
    color: #1C508F;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .reviews__more:hover {
    opacity: 0.75;
  }

  .reviews__more svg {
    flex-shrink: 0;
  }

  /* ===== Кнопка ===== */
  .reviews__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 330px;
    height: 85px;
    background: #1C508F;
    box-shadow: 0px 0px 4px rgba(0, 0, 0, 0.3);
    border-radius: 9px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #FFFFFF;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .reviews__btn:hover {
    background: #174480;
  }

  /* === МОБИЛЬНАЯ ВЕРСИЯ === */
  @media (max-width: 768px) {
    .reviews {
      padding: 45px 0;
    }

    .reviews__inner {
      width: 100%;
      padding: 0 23px;
      gap: 45px;
    }

    .reviews__title {
      font-size: 24px;
      line-height: 110%;
    }

    .reviews__slider-wrap {
      width: 100%;
      overflow: visible;
      min-height: 440px;
      padding: 10px 0;
    }

    .reviews__slider {
      overflow: visible;
      min-height: 440px;
    }

    .reviews__slide {
      display: none;
    }

    .reviews__slide--active {
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .reviews__slide--active::-webkit-scrollbar {
      display: none;
    }

    .reviews__grid {
      display: flex;
      flex-direction: row;
      gap: 10px;
      grid-template-columns: none;
    }

    .reviews__card {
      width: 274px;
      height: 400px;
      flex-shrink: 0;
      scroll-snap-align: start;
    }

    .reviews__quote {
      left: 15px;
      top: 12px;
      font-size: 96px;
      line-height: 110%;
    }

    .reviews__card-inner {
      width: 244px;
      height: 292px;
      left: 15px;
      top: 83px;
      gap: 25px;
    }

    .reviews__card-top {
      width: 244px;
      height: 245px;
      gap: 77px;
    }

    .reviews__card-text {
      width: 244px;
      font-size: 16px;
      line-height: 130%;
    }

    .reviews__card-line {
      width: 244px;
    }

    .reviews__card-author-wrap {
      width: 200px;
      height: 22px;
    }

    .reviews__card-author {
      width: 200px;
      height: 22px;
      font-size: 20px;
      line-height: 110%;
    }

    .reviews__arrow {
      display: none;
    }

    .reviews__bottom {
      width: 100%;
      flex-direction: column;
      gap: 30px;
      align-items: flex-end;
    }

    .reviews__scrollbar {
      display: block;
      position: relative;
      width: 100%;
      height: 13px;
      order: 1;
    }

    .reviews__scrollbar-track {
      position: absolute;
      width: 100%;
      height: 7px;
      left: 0;
      top: 3px;
      background: #C0C0C0;
      border-radius: 100px;
    }

    .reviews__scrollbar-thumb {
      position: absolute;
      width: 94px;
      height: 13px;
      left: 0;
      top: 0;
      background: #1C508F;
      border-radius: 100px;
      cursor: pointer;
      transition: left 0.1s ease-out;
    }

    .reviews__dots {
      display: none;
    }

    .reviews__more {
      font-size: 16px;
      line-height: 130%;
      order: 0;
      color: #000000;
    }

    .reviews__more svg {
      width: 12.73px;
      height: 13.44px;
    }

    .reviews__more svg path {
      stroke: #000000;
    }

    .reviews__btn {
      width: 100%;
      height: 85px;
      font-size: 16px;
      line-height: 130%;
    }
  }
</style>

<script>
  const reviewsSlides     = document.querySelectorAll('.reviews__slide');
  const reviewsDots       = document.querySelectorAll('.reviews__dot');
  const reviewsArrowRight = document.getElementById('reviewsArrowRight');
  const reviewsArrowLeft  = document.getElementById('reviewsArrowLeft');

  let reviewsCurrent = 0;
  const reviewsTotal = reviewsSlides.length;

  function reviewsGoTo(index: number) {
    reviewsSlides[reviewsCurrent].classList.remove('reviews__slide--active');
    reviewsDots[reviewsCurrent].classList.remove('reviews__dot--active');

    reviewsCurrent = index;

    reviewsSlides[reviewsCurrent].classList.add('reviews__slide--active');
    reviewsDots[reviewsCurrent].classList.add('reviews__dot--active');

    reviewsArrowLeft?.classList.toggle('is-hidden', reviewsCurrent === 0);
    reviewsArrowRight?.classList.toggle('is-hidden', reviewsCurrent === reviewsTotal - 1);
  }

  // Инициализация
  reviewsArrowLeft?.classList.add('is-hidden');
  if (reviewsTotal <= 1) reviewsArrowRight?.classList.add('is-hidden');

  reviewsArrowRight?.addEventListener('click', () => {
    if (reviewsCurrent < reviewsTotal - 1) reviewsGoTo(reviewsCurrent + 1);
  });

  reviewsArrowLeft?.addEventListener('click', () => {
    if (reviewsCurrent > 0) reviewsGoTo(reviewsCurrent - 1);
  });

  reviewsDots.forEach((dot, i) => {
    dot.addEventListener('click', () => reviewsGoTo(i));
  });

  // Мобильный скроллбар для Reviews
  function initReviewsScrollbar() {
    if (window.innerWidth > 768) return;

    const activeSlide = document.querySelector('.reviews__slide--active') as HTMLElement;
    const scrollbarThumb = document.getElementById('reviewsScrollbarThumb') as HTMLElement;
    const scrollbar = document.getElementById('reviewsScrollbar') as HTMLElement;

    if (!activeSlide || !scrollbarThumb || !scrollbar) return;

    function updateThumbPosition() {
      const scrollLeft = activeSlide.scrollLeft;
      const scrollWidth = activeSlide.scrollWidth;
      const clientWidth = activeSlide.clientWidth;

      if (scrollWidth <= clientWidth) return;

      const scrollableWidth = scrollWidth - clientWidth;
      const scrollbarWidth = scrollbar.clientWidth;
      const thumbWidth = scrollbarThumb.clientWidth;
      const maxThumbPosition = scrollbarWidth - thumbWidth;

      const thumbPosition = (scrollLeft / scrollableWidth) * maxThumbPosition;
      scrollbarThumb.style.left = `${thumbPosition}px`;
    }

    // Синхронизация при скролле контента
    activeSlide.addEventListener('scroll', updateThumbPosition);

    // Драг скроллбара
    let isDragging = false;
    let startX = 0;
    let startLeft = 0;

    scrollbarThumb.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      startLeft = parseInt(scrollbarThumb.style.left || '0');
      e.preventDefault();
    });

    scrollbarThumb.addEventListener('touchstart', (e) => {
      isDragging = true;
      startX = e.touches[0].clientX;
      startLeft = parseInt(scrollbarThumb.style.left || '0');
      e.preventDefault();
    });

    const handleMove = (clientX: number) => {
      if (!isDragging) return;

      const deltaX = clientX - startX;
      const scrollbarWidth = scrollbar.clientWidth;
      const thumbWidth = scrollbarThumb.clientWidth;
      const maxThumbPosition = scrollbarWidth - thumbWidth;

      let newLeft = startLeft + deltaX;
      newLeft = Math.max(0, Math.min(newLeft, maxThumbPosition));

      const scrollWidth = activeSlide.scrollWidth;
      const clientWidth = activeSlide.clientWidth;
      const scrollableWidth = scrollWidth - clientWidth;

      const scrollPosition = (newLeft / maxThumbPosition) * scrollableWidth;
      activeSlide.scrollLeft = scrollPosition;
    };

    document.addEventListener('mousemove', (e) => handleMove(e.clientX));
    document.addEventListener('touchmove', (e) => handleMove(e.touches[0].clientX));

    document.addEventListener('mouseup', () => {
      isDragging = false;
    });

    document.addEventListener('touchend', () => {
      isDragging = false;
    });

    // Клик по треку
    scrollbar.addEventListener('click', (e) => {
      if (e.target === scrollbarThumb) return;

      const rect = scrollbar.getBoundingClientRect();
      const clickX = e.clientX - rect.left;
      const thumbWidth = scrollbarThumb.clientWidth;
      const scrollbarWidth = scrollbar.clientWidth;
      const maxThumbPosition = scrollbarWidth - thumbWidth;

      const newLeft = Math.max(0, Math.min(clickX - thumbWidth / 2, maxThumbPosition));

      const scrollWidth = activeSlide.scrollWidth;
      const clientWidth = activeSlide.clientWidth;
      const scrollableWidth = scrollWidth - clientWidth;

      const scrollPosition = (newLeft / maxThumbPosition) * scrollableWidth;
      activeSlide.scrollLeft = scrollPosition;
    });

    updateThumbPosition();
  }

  initReviewsScrollbar();

  window.addEventListener('resize', () => {
    initReviewsScrollbar();
  });
</script>