---
import type { Lang } from '../../utils/i18n';

interface Props {
  t: any;
  lang: Lang;
}

const { t, lang } = Astro.props;
---

<section class="about">
  <div class="about__inner">

    <!-- Заголовок -->
    <h2 class="about__title">{t.about.title}</h2>

    <div class="about__content">

      <!-- Блок 1: фото слева + текст справа -->
      <div class="about__row about__row--first">

        <!-- Фото -->
        <div class="about__image-wrap">
          <img src="/assets/images/about-1.png" alt={t.about.title} class="about__image" />
        </div>

        <!-- Текст справа -->
        <div class="about__text-col">

          <div class="about__text-block">
            <p class="about__text">
              {t.about.intro_1}
            </p>
            <p class="about__text">
              {t.about.intro_2}
            </p>
          </div>

          <!-- Карточки преимуществ -->
          <div class="about__features">

            <!-- Гарантия качества -->
            <div class="about__feature">
              <div class="about__feature-icon">
                <img src="/assets/icons/guarantee.svg" alt={t.about.feature_quality_title} width="63" height="63" />
              </div>
              <h4 class="about__feature-title">{t.about.feature_quality_title}</h4>
              <p class="about__feature-text">
                {t.about.feature_quality_text}
              </p>
            </div>

            <!-- Проектная оптимизация -->
            <div class="about__feature">
              <div class="about__feature-icon">
                <img src="/assets/icons/workflow.svg" alt={t.about.feature_optimization_title} width="63" height="63" />
              </div>
              <h4 class="about__feature-title">{t.about.feature_optimization_title}</h4>
              <p class="about__feature-text">
                {t.about.feature_optimization_text}
              </p>
            </div>

          </div>
        </div>
      </div>

      <!-- Блок 2: текст слева + фото справа -->
      <div class="about__row about__row--second">

        <!-- Текст слева -->
        <div class="about__text-col about__text-col--left">
          <p class="about__text">
            {t.about.partners_intro}
          </p>
          <ul class="about__list">
            <li>{t.about.partner_berent}</li>
            <li>{t.about.partner_ekf}</li>
            <li>{t.about.partner_sensh}</li>
          </ul>
          <p class="about__text">
            {t.about.conclusion}
          </p>
        </div>

        <!-- Фото -->
        <div class="about__image-wrap">
          <img src="/assets/images/about-2.png" alt={`${t.about.title} ${t.nav.products}`} class="about__image" />
        </div>

      </div>

    </div>

    <!-- Кнопка -->
    <div class="about__cta">
      <a href={`/${lang}/contacts`} class="about__btn">{t.about.btn_consultation}</a>
    </div>

  </div>
</section>

<style>
  .about {
    width: 100%;
    background: #FFFFFF;
    padding: 110px 0 55px;
  }

  .about__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 60px;
    width: 1413px;
    margin: 0 auto;
  }

  /* === Заголовок === */
  .about__title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 48px;
    line-height: 110%;
    color: #000000;
    width: 100%;
  }

  /* === Контент === */
  .about__content {
    display: flex;
    flex-direction: column;
    gap: 50px;
    width: 100%;
  }

  /* === Строки === */
  .about__row {
    display: flex;
    flex-direction: row;
    align-items: center;
    width: 100%;
  }

  .about__row--first {
    gap: 30px;
    align-items: flex-start;
  }

  .about__row--second {
    gap: 31px;
    align-items: flex-start;
  }

  /* === Фото === */
  .about__image-wrap {
    flex-shrink: 0;
    width: 690px;
    height: 480px;
    border-radius: 8px;
    overflow: hidden;
    background: #B0B0B0;
    position: relative;
  }

  .about__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* === Текстовая колонка === */
  .about__text-col {
    display: flex;
    flex-direction: column;
    gap: 25px;
    width: 691px;
    flex-shrink: 0;
  }

  .about__text-col--left {
    width: 690px;
    gap: 20px;
  }

  /* === Текстовый блок === */
  .about__text-block {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .about__text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #000000;
  }

  /* === Список партнёров === */
  .about__list {
    list-style: disc;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .about__list li {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #000000;
  }

  /* === Карточки преимуществ === */
  .about__features {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 20px;
    width: 683px;
  }

  .about__feature {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 25px;
    flex: 1;
  }

  /* Иконка в круглом фоне */
  .about__feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 102px;
    height: 102px;
    background: #4D77AA;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .about__feature-icon img {
    width: 63px;
    height: 63px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .about__feature-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 20px;
    line-height: 110%;
    letter-spacing: -0.01em;
    color: #000000;
  }

  .about__feature-text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #000000;
  }

  /* === Кнопка === */
  .about__cta {
    width: 100%;
  }

  .about__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 330px;
    height: 85px;
    background: #1C508F;
    box-shadow: 0px 0px 4px rgba(0, 0, 0, 0.3);
    border-radius: 9px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #FFFFFF;
    transition: background 0.2s ease;
  }

  .about__btn:hover {
    background: #174480;
  }
</style>