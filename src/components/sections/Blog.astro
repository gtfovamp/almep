---
import type { Lang } from '../../utils/i18n';
import { env } from 'cloudflare:workers';
import { timeAgo } from '../../lib/time-helpers';

interface Props {
  t: any;
  lang: Lang;
}

const { t, lang } = Astro.props;

// Load latest blog post from database
let latestPost: any = null;
try {
  const db = env.DB;
  if (db) {
    const { results } = await db.prepare(
      'SELECT * FROM blog ORDER BY published_at DESC LIMIT 1'
    ).all();

    if (results && results.length > 0) {
      const post = results[0];

      // Parse blocks
      const blocks = JSON.parse(post.blocks || '[]');

      // Get title in current language
      const title = post[`title_${lang}`] || post.title;

      // Extract excerpt from first text block
      const textBlock = blocks.find((b: any) => b.type === 'text');
      const excerptText = textBlock?.data?.[`text_${lang}`] || textBlock?.data?.text_ru || '';
      const excerpt = excerptText.substring(0, 200) + (excerptText.length > 200 ? '...' : '');

      // Calculate time ago
      const publishedTimeAgo = timeAgo(post.published_at, lang);

      latestPost = {
        id: post.id,
        title,
        excerpt,
        timeAgo: publishedTimeAgo,
        coverImage: post.cover_image_url
      };
    }
  }
} catch (error) {
  console.error('Error fetching blog post:', error);
}
---

<section class="blog">

  <!-- Фоновое изображение -->
  <div class="blog__bg" style={latestPost ? `background-image: url('${latestPost.coverImage}')` : ''}></div>

  <!-- Белая карточка -->
  <div class="blog__card">
    <div class="blog__card-inner">

      <!-- Заголовок секции -->
      <h2 class="blog__title">{t.blog.title}</h2>

      <!-- Контент -->
      <div class="blog__content">

        <div class="blog__text-wrap">
          <!-- Заголовок статьи -->
          <h3 class="blog__post-title">{latestPost ? latestPost.title : t.blog.post_title}</h3>

          <!-- Текст -->
          <p class="blog__post-text">
            {latestPost ? latestPost.excerpt : t.blog.post_text}
          </p>

          <!-- Время публикации -->
          {latestPost && (
            <p class="blog__post-time">{latestPost.timeAgo}</p>
          )}
        </div>

        <!-- Ссылка "Читать дальше" -->
        <a href={latestPost ? `/${lang}/blog/${latestPost.id}` : `/${lang}/blog/1`} class="blog__read-more">
          <span class="blog__read-more-text">{t.blog.read_more}</span>
          <span class="blog__read-more-line"></span>
        </a>

      </div>

    </div>
  </div>

</section>

<style>
  /* ===== Секция ===== */
  .blog {
    position: relative;
    width: 100%;
    height: 750px;
    background: #000000;
    overflow: hidden;
  }

  /* ===== Фон ===== */
  .blog__bg {
    position: absolute;
    inset: 0;
    background-image: url('/assets/images/blog-bg.png');
    background-size: cover;
    background-position: center right;
    background-repeat: no-repeat;
  }

  /* Тёмный оверлей слева */
  .blog__bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.84) 0%,
      rgba(0, 0, 0, 0.76) 40%,
      rgba(0, 0, 0, 0.0) 70%
    );
  }

  /* ===== Белая карточка ===== */
  .blog__card {
    position: absolute;
    width: 932px;
    height: 460px;
    left: 93px;
    top: 50%;
    transform: translateY(-50%);
    background: #FFFFFF;
    border-radius: 17px;
  }

  /* ===== Внутренний контейнер карточки ===== */
  .blog__card-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 50px;
    position: absolute;
    width: 764px;
    left: 55px;
    top: 50%;
    transform: translateY(-50%);
  }

  /* ===== Заголовок "Блог" ===== */
  .blog__title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 48px;
    line-height: 110%;
    color: #0E0E0E;
    margin: 0;
    width: 100%;
  }

  /* ===== Блок контента ===== */
  .blog__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 50px;
    width: 790px;
  }

  /* ===== Текстовый блок ===== */
  .blog__text-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    width: 100%;
  }

  /* ===== Заголовок статьи ===== */
  .blog__post-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 110%;
    letter-spacing: -0.01em;
    color: #0E0E0E;
    margin: 0;
    width: 100%;
  }

  /* ===== Текст статьи ===== */
  .blog__post-text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #0E0E0E;
    margin: 0;
    width: 100%;
  }

  /* ===== Время публикации ===== */
  .blog__post-time {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 130%;
    color: #666666;
    margin: 0;
  }

  /* ===== Ссылка "Читать дальше" ===== */
  .blog__read-more {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 5px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .blog__read-more:hover {
    opacity: 0.7;
  }

  .blog__read-more-text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #0E0E0E;
    white-space: nowrap;
  }

  .blog__read-more-line {
    display: block;
    width: 149px;
    height: 1px;
    background: #0E0E0E;
  }

  /* === МОБИЛЬНАЯ ВЕРСИЯ === */
  @media (max-width: 768px) {
    .blog {
      height: 706px;
    }

    .blog__bg {
      background-position: center;
    }

    .blog__bg::before {
      background: linear-gradient(
        to right,
        rgba(0, 0, 0, 0.76) 0%,
        rgba(0, 0, 0, 0.76) 100%
      );
    }

    .blog__card {
      width: 274px;
      height: 616px;
      left: 50%;
      transform: translate(-50%, -50%);
      border-radius: 17px;
    }

    .blog__card-inner {
      width: 244px;
      left: 50%;
      transform: translate(-50%, -50%);
      gap: 25px;
    }

    .blog__title {
      font-size: 24px;
      line-height: 110%;
    }

    .blog__content {
      width: 100%;
      gap: 20px;
    }

    .blog__text-wrap {
      gap: 20px;
    }

    .blog__post-title {
      font-size: 20px;
      line-height: 110%;
    }

    .blog__post-text {
      font-size: 16px;
      line-height: 130%;
    }

    .blog__post-time {
      font-size: 14px;
    }

    .blog__read-more {
      gap: 5px;
    }

    .blog__read-more-text {
      font-size: 18px;
      line-height: 130%;
    }

    .blog__read-more-line {
      width: 148px;
    }
  }
</style>