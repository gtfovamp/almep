---
import { env } from 'cloudflare:workers';
import type { Lang } from '../../utils/i18n';

export const prerender = false;

interface Props {
  t: any;
  lang: Lang;
}

const { t, lang } = Astro.props;

// Fetch portfolio items from API
let portfolioItems = [];
try {
  const db = env.DB;
  if (db) {
    const { results } = await db.prepare(
      'SELECT * FROM portfolio ORDER BY order_index ASC LIMIT 9'
    ).all();

    portfolioItems = results.map((item: any) => ({
      image: item.image_url,
      title: lang === 'en' ? (item.title_en || item.title) :
             lang === 'az' ? (item.title_az || item.title) :
             item.title,
      year: item.year
    }));
  }
} catch (error) {
  console.error('Error fetching portfolio:', error);
}

const slides = [];
for (let i = 0; i < portfolioItems.length; i += 6) {
  slides.push(portfolioItems.slice(i, i + 6));
}
---

<section class="portfolio">
  <div class="portfolio__inner">

    <h2 class="portfolio__title">{t.portfolio.title}</h2>

    <div class="portfolio__slider-wrap">

      <div class="portfolio__slider" id="portfolioSlider">
        {slides.map((slide, slideIndex) => (
          <div class={`portfolio__slide ${slideIndex === 0 ? 'portfolio__slide--active' : ''}`}>
            <div class="portfolio__grid">
              {slide.map((item) => (
                <div class="portfolio__card">
                  <img
                    src={item.image}
                    alt={item.title}
                    class="portfolio__card-img"
                  />
                  <div class="portfolio__card-caption">
                    <span class="portfolio__card-title">{item.title}</span>
                    <span class="portfolio__card-year">{item.year}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <button class="portfolio__arrow portfolio__arrow--right" id="arrowRight" aria-label={t.portfolio.aria_next}>
        <svg width="23" height="30" viewBox="0 0 23 30" fill="none">
          <path d="M3 3L20 15L3 27" stroke="#000000" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <button class="portfolio__arrow portfolio__arrow--left" id="arrowLeft" aria-label={t.portfolio.aria_prev}>
        <svg width="23" height="30" viewBox="0 0 23 30" fill="none">
          <path d="M20 3L3 15L20 27" stroke="#000000" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>

    <div class="portfolio__bottom">

      <div class="portfolio__scrollbar" id="portfolioScrollbar">
        <div class="portfolio__scrollbar-track"></div>
        <div class="portfolio__scrollbar-thumb" id="portfolioScrollbarThumb"></div>
      </div>

      <div></div>

      <div class="portfolio__dots" id="portfolioDots">
        {slides.map((_, i) => (
          <button
            class={`portfolio__dot ${i === 0 ? 'portfolio__dot--active' : ''}`}
            data-index={i}
            aria-label={`${t.portfolio.aria_slide} ${i + 1}`}
          />
        ))}
      </div>

      <a href={`/${lang}/portfolio`} class="portfolio__more">
        {t.portfolio.learn_more}
        <svg width="27" height="20" viewBox="0 0 27 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0.013702 10.394L26.1767 9.68691M26.1767 9.68691L16.8428 0.353097M26.1767 9.68691L16.9401 18.9235" stroke="#1C508F"/>
        </svg>
      </a>

    </div>

    <div class="portfolio__cta">
      <a href={`/${lang}/contacts`} class="portfolio__btn">{t.portfolio.btn_consultation}</a>
    </div>

  </div>
</section>

<style>
  .portfolio {
    width: 100%;
    background: #FFFFFF;
    padding: 55px 0 55px;
  }

  .portfolio__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 46px;
    width: 1448px;
    margin: 0 auto;
  }

  .portfolio__title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 48px;
    line-height: 110%;
    color: #000000;
    width: 100%;
  }

  .portfolio__slider-wrap {
    position: relative;
    width: 1410px;
  }

  .portfolio__slider {
    width: 100%;
    overflow: hidden;
  }

  .portfolio__slide {
    display: none;
  }

  .portfolio__slide--active {
    display: block;
  }

  .portfolio__grid {
    display: grid;
    grid-template-columns: repeat(3, 450px);
    grid-template-rows: repeat(2, 330px);
    gap: 30px;
  }

  .portfolio__card {
    position: relative;
    width: 450px;
    height: 330px;
    background: #FFFFFF;
    box-shadow: 0px 0px 4px rgba(0, 0, 0, 0.3);
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .portfolio__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .portfolio__card:hover .portfolio__card-img {
    transform: scale(1.03);
  }

  .portfolio__card-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 111px;
    background: rgba(255, 255, 255, 0.88);
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    padding: 26px 15px 0;
    gap: 42px;
    box-sizing: border-box;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .portfolio__card:hover .portfolio__card-caption {
    opacity: 1;
    transform: translateY(0);
  }

  .portfolio__card-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 110%;
    letter-spacing: -0.01em;
    color: #1C508F;
    flex: 1;
  }

  .portfolio__card-year {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 110%;
    letter-spacing: -0.01em;
    color: #1C508F;
    white-space: nowrap;
  }

  .portfolio__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 76px;
    height: 76px;
    background: #F1F1F1;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
    z-index: 10;
  }

  .portfolio__arrow:hover {
    background: #E0E0E0;
  }

  .portfolio__arrow--right {
    right: -38px;
  }

  .portfolio__arrow--left {
    left: -38px;
  }

  .portfolio__arrow--left.is-hidden,
  .portfolio__arrow--right.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .portfolio__bottom {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 1410px;
    position: relative;
  }

  .portfolio__dots {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .portfolio__dot {
    width: 17px;
    height: 17px;
    border-radius: 50%;
    border: none;
    background: #D9D9D9;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;
  }

  .portfolio__dot--active {
    background: #1C508F;
  }

  .portfolio__more {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 11px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 24px;
    line-height: 110%;
    color: #1C508F;
    transition: opacity 0.2s;
  }

  .portfolio__more:hover {
    opacity: 0.75;
  }

  .portfolio__more svg {
    flex-shrink: 0;
  }

  .portfolio__cta {
    width: 100%;
  }

  .portfolio__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 330px;
    height: 85px;
    background: #1C508F;
    box-shadow: 0px 0px 4px rgba(0, 0, 0, 0.3);
    border-radius: 9px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 130%;
    letter-spacing: -0.01em;
    color: #FFFFFF;
    transition: background 0.2s ease;
  }

  .portfolio__btn:hover {
    background: #174480;
  }

  /* === МОБИЛЬНАЯ ВЕРСИЯ === */
  @media (max-width: 768px) {
    .portfolio {
      padding: 45px 0;
    }

    .portfolio__inner {
      width: 100%;
      padding: 0 23px;
      gap: 45px;
    }

    .portfolio__title {
      font-size: 24px;
      line-height: 110%;
    }

    .portfolio__slider-wrap {
      width: 100%;
      overflow: visible;
    }

    .portfolio__slider {
      overflow: visible;
    }

    .portfolio__slide {
      display: none;
    }

    .portfolio__slide--active {
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .portfolio__slide--active::-webkit-scrollbar {
      display: none;
    }

    .portfolio__grid {
      display: flex;
      flex-direction: row;
      gap: 11px;
      grid-template-columns: none;
      grid-template-rows: none;
    }

    .portfolio__card {
      width: 274px;
      height: 330px;
      flex-shrink: 0;
      scroll-snap-align: start;
      border-radius: 7px;
    }

    .portfolio__card-caption {
      height: 166px;
      padding: 15px;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      gap: 42px;
      opacity: 1;
      transform: translateY(0);
    }

    .portfolio__card-title {
      font-size: 20px;
      line-height: 110%;
      order: 0;
    }

    .portfolio__card-year {
      font-size: 20px;
      line-height: 110%;
      order: 1;
      align-self: flex-start;
    }

    .portfolio__arrow {
      display: none;
    }

    .portfolio__bottom {
      width: 100%;
      flex-direction: column;
      gap: 35px;
      align-items: flex-start;
    }

    .portfolio__scrollbar {
      display: block;
      position: relative;
      width: 100%;
      height: 13px;
      order: 0;
    }

    .portfolio__scrollbar-track {
      position: absolute;
      width: 100%;
      height: 7px;
      left: 0;
      top: 3px;
      background: #C0C0C0;
      border-radius: 100px;
    }

    .portfolio__scrollbar-thumb {
      position: absolute;
      width: 94px;
      height: 13px;
      left: 0;
      top: 0;
      background: #1C508F;
      border-radius: 100px;
      cursor: pointer;
      transition: left 0.1s ease-out;
    }

    .portfolio__dots {
      display: none;
    }

    .portfolio__more {
      font-size: 16px;
      line-height: 130%;
      order: -1;
      align-self: flex-end;
    }

    .portfolio__more svg {
      width: 18.5px;
      height: 13.44px;
    }

    .portfolio__btn {
      width: 100%;
      height: 85px;
      font-size: 16px;
      line-height: 130%;
    }
  }
</style>

<script>
  const slides = document.querySelectorAll('.portfolio__slide');
  const dots = document.querySelectorAll('.portfolio__dot');
  const arrowRight = document.getElementById('arrowRight');
  const arrowLeft = document.getElementById('arrowLeft');

  let current = 0;
  const total = slides.length;

  function goTo(index: number) {
    slides[current].classList.remove('portfolio__slide--active');
    dots[current].classList.remove('portfolio__dot--active');

    current = index;

    slides[current].classList.add('portfolio__slide--active');
    dots[current].classList.add('portfolio__dot--active');

    arrowLeft?.classList.toggle('is-hidden', current === 0);
    arrowRight?.classList.toggle('is-hidden', current === total - 1);
  }

  arrowLeft?.classList.add('is-hidden');
  if (total <= 1) arrowRight?.classList.add('is-hidden');

  arrowRight?.addEventListener('click', () => {
    if (current < total - 1) goTo(current + 1);
  });

  arrowLeft?.addEventListener('click', () => {
    if (current > 0) goTo(current - 1);
  });

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i));
  });

  // Мобильный скроллбар
  function initMobileScrollbar() {
    if (window.innerWidth > 768) return;

    const activeSlide = document.querySelector('.portfolio__slide--active') as HTMLElement;
    const scrollbarThumb = document.getElementById('portfolioScrollbarThumb') as HTMLElement;
    const scrollbar = document.getElementById('portfolioScrollbar') as HTMLElement;

    if (!activeSlide || !scrollbarThumb || !scrollbar) return;

    function updateThumbPosition() {
      const scrollLeft = activeSlide.scrollLeft;
      const scrollWidth = activeSlide.scrollWidth;
      const clientWidth = activeSlide.clientWidth;

      if (scrollWidth <= clientWidth) return;

      const scrollableWidth = scrollWidth - clientWidth;
      const scrollbarWidth = scrollbar.clientWidth;
      const thumbWidth = scrollbarThumb.clientWidth;
      const maxThumbPosition = scrollbarWidth - thumbWidth;

      const thumbPosition = (scrollLeft / scrollableWidth) * maxThumbPosition;
      scrollbarThumb.style.left = `${thumbPosition}px`;
    }

    // Синхронизация при скролле контента
    activeSlide.addEventListener('scroll', updateThumbPosition);

    // Драг скроллбара
    let isDragging = false;
    let startX = 0;
    let startLeft = 0;

    scrollbarThumb.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      startLeft = parseInt(scrollbarThumb.style.left || '0');
      e.preventDefault();
    });

    scrollbarThumb.addEventListener('touchstart', (e) => {
      isDragging = true;
      startX = e.touches[0].clientX;
      startLeft = parseInt(scrollbarThumb.style.left || '0');
      e.preventDefault();
    });

    const handleMove = (clientX: number) => {
      if (!isDragging) return;

      const deltaX = clientX - startX;
      const scrollbarWidth = scrollbar.clientWidth;
      const thumbWidth = scrollbarThumb.clientWidth;
      const maxThumbPosition = scrollbarWidth - thumbWidth;

      let newLeft = startLeft + deltaX;
      newLeft = Math.max(0, Math.min(newLeft, maxThumbPosition));

      const scrollWidth = activeSlide.scrollWidth;
      const clientWidth = activeSlide.clientWidth;
      const scrollableWidth = scrollWidth - clientWidth;

      const scrollPosition = (newLeft / maxThumbPosition) * scrollableWidth;
      activeSlide.scrollLeft = scrollPosition;
    };

    document.addEventListener('mousemove', (e) => handleMove(e.clientX));
    document.addEventListener('touchmove', (e) => handleMove(e.touches[0].clientX));

    document.addEventListener('mouseup', () => {
      isDragging = false;
    });

    document.addEventListener('touchend', () => {
      isDragging = false;
    });

    // Клик по треку
    scrollbar.addEventListener('click', (e) => {
      if (e.target === scrollbarThumb) return;

      const rect = scrollbar.getBoundingClientRect();
      const clickX = e.clientX - rect.left;
      const thumbWidth = scrollbarThumb.clientWidth;
      const scrollbarWidth = scrollbar.clientWidth;
      const maxThumbPosition = scrollbarWidth - thumbWidth;

      const newLeft = Math.max(0, Math.min(clickX - thumbWidth / 2, maxThumbPosition));

      const scrollWidth = activeSlide.scrollWidth;
      const clientWidth = activeSlide.clientWidth;
      const scrollableWidth = scrollWidth - clientWidth;

      const scrollPosition = (newLeft / maxThumbPosition) * scrollableWidth;
      activeSlide.scrollLeft = scrollPosition;
    });

    updateThumbPosition();
  }

  initMobileScrollbar();

  window.addEventListener('resize', () => {
    initMobileScrollbar();
  });
</script>